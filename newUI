        U.New("Frame",{BackgroundColor3=T.BrdCard,Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,1,-1),Parent=ph})

        local grid = U.New("Frame",{BackgroundTransparency=1,Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,LayoutOrder=1,Parent=page})
        local colL = U.New("Frame",{BackgroundTransparency=1,Position=UDim2.new(0,0,0,0),Size=UDim2.new(0.5,-6,0,0),AutomaticSize=Enum.AutomaticSize.Y,Parent=grid})
        U.New("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,8),Parent=colL})
        local colR = U.New("Frame",{BackgroundTransparency=1,Position=UDim2.new(0.5,6,0,0),Size=UDim2.new(0.5,-6,0,0),AutomaticSize=Enum.AutomaticSize.Y,Parent=grid})
        U.New("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,8),Parent=colR})
        local colIdx = 0

        table.insert(Win._tabs, page)
        table.insert(Win._btns, {btn=btn, lbl=lbl, ul=ul})

        btn.MouseButton1Click:Connect(function()
            U.Ripple(btn, Mouse.X, Mouse.Y)
            ActivateTab(btn, ul, page)
        end)

        if #Win._tabs == 1 then
            task.defer(function() ActivateTab(btn, ul, page) end)
        end

        local Tab = {}

        function Tab:AddSection(sname)
            colIdx = colIdx + 1
            local col = (colIdx % 2 == 1) and colL or colR
            local card = MakeSectionCard(sname, col, colIdx)
            local Sec = {} local iOrd = 0

            -- helper row basico
            local function Row(lbl_, h)
                iOrd = iOrd + 1
                local r = U.New("Frame",{BackgroundTransparency=1,Size=UDim2.new(1,0,0,h or 34),LayoutOrder=iOrd,Parent=card})
                U.New("TextLabel",{BackgroundTransparency=1,Position=UDim2.new(0,0,0.5,-7),Size=UDim2.new(0.54,-4,0,14),Text=lbl_,TextColor3=T.TxtPri,Font=T.FntBody,TextSize=10,TextXAlignment=Enum.TextXAlignment.Left,Parent=r})
                return r
            end

            -- ── Toggle ────────────────────────────────────────────────────────
            -- FIX: ActivePanel agora sempre sincroniza no Set, inclusive inicial
            function Sec:AddToggle(c)
                c = c or {}
                local row   = Row(c.Name or "Toggle")
                local state = c.Default or false
                local cb    = c.Callback or function() end
                local tName = c.Name or "Toggle"

                local track = U.New("Frame",{
                    BackgroundColor3=T.Input, Position=UDim2.new(1,-50,0.5,-10),
                    Size=UDim2.new(0,44,0,20), Parent=row
                })
                U.Corner(track,999) U.Stroke(track,T.BrdElem,1,0)
                local fill  = U.New("Frame",{BackgroundColor3=T.Red,Size=UDim2.new(0,0,1,0),ClipsDescendants=true,Parent=track}) U.Corner(fill,999)
                local thumb = U.New("Frame",{BackgroundColor3=Color3.new(1,1,1),Position=UDim2.new(0,2,0.5,-7),Size=UDim2.new(0,14,0,14),ZIndex=3,Parent=track}) U.Corner(thumb,999)

                local o = {}

                local function Upd(s, ani)
                    if s then
                        if ani then
                            U.Tw(fill,{Size=UDim2.new(1,0,1,0)},0.18)
                            U.Tw(thumb,{Position=UDim2.new(1,-16,0.5,-7),BackgroundColor3=T.RedLight},0.18)
                            U.Tw(track,{BackgroundColor3=T.RedDark},0.18)
                        else
                            fill.Size=UDim2.new(1,0,1,0)
                            thumb.Position=UDim2.new(1,-16,0.5,-7)
                            thumb.BackgroundColor3=T.RedLight
                            track.BackgroundColor3=T.RedDark
                        end
                    else
                        if ani then
                            U.Tw(fill,{Size=UDim2.new(0,0,1,0)},0.18)
                            U.Tw(thumb,{Position=UDim2.new(0,2,0.5,-7),BackgroundColor3=Color3.new(1,1,1)},0.18)
                            U.Tw(track,{BackgroundColor3=T.Input},0.18)
                        else
                            fill.Size=UDim2.new(0,0,1,0)
                            thumb.Position=UDim2.new(0,2,0.5,-7)
                            thumb.BackgroundColor3=Color3.new(1,1,1)
                            track.BackgroundColor3=T.Input
                        end
                    end
                    -- FIX: sempre sincroniza o painel
                    ActivePanel:Set(tName, s)
                end

                function o:Set(v, silent)
                    state = v
                    Upd(v, true)
                    if not silent then cb(v) end
                end
                function o:Get() return state end

                Upd(state, false)
                ConfigSystem:Register(tName, o)

                local hit = U.New("TextButton",{BackgroundTransparency=1,Size=UDim2.new(1,0,1,0),Text="",ZIndex=5,Parent=row})
                hit.MouseButton1Click:Connect(function()
                    state = not state
                    Upd(state, true)
                    cb(state)
                end)
                return o
            end

            -- ── Keybind ───────────────────────────────────────────────────────
            function Sec:AddBind(c)
                c = c or {}
                local row  = Row(c.Name or "Keybind")
                local bkey = c.Default
                local lst  = false
                local cb   = c.Callback or function() end
                local toggle = c.Toggle

                local chip = U.New("TextButton",{
                    BackgroundColor3=T.Input, Position=UDim2.new(1,-76,0.5,-11),
                    Size=UDim2.new(0,72,0,22), Text=bkey and bkey.Name or "None",
                    TextColor3=bkey and T.RedLight or T.TxtMute, Font=T.FntMono, TextSize=9,
                    ClipsDescendants=true, Parent=row
                })
                U.Corner(chip,5) U.Stroke(chip,T.BrdElem,1,0)

                chip.MouseButton1Click:Connect(function()
                    if lst then return end lst=true chip.Text="..." chip.TextColor3=T.Red
                    local con; con = UserInputService.InputBegan:Connect(function(i,gp)
                        if gp then return end
                        if i.UserInputType == Enum.UserInputType.Keyboard then
                            if i.KeyCode == Enum.KeyCode.Escape then
                                bkey=nil chip.Text="None" chip.TextColor3=T.TxtMute
                            else
                                bkey=i.KeyCode chip.Text=i.KeyCode.Name chip.TextColor3=T.RedLight
                            end
                            lst=false con:Disconnect()
                        end
                    end)
                end)

                UserInputService.InputBegan:Connect(function(i,gp)
                    if not gp and bkey and i.KeyCode == bkey then
                        cb()
                        if toggle then toggle:Set(not toggle:Get(), false) end
                    end
                end)

                local o = {}
                function o:Set(v) bkey=v chip.Text=v and v.Name or "None" chip.TextColor3=v and T.RedLight or T.TxtMute end
                function o:Get() return bkey end
                if c.Name then
                    ConfigSystem:Register(c.Name,{
                        Get=function() return bkey and bkey.Name or "None" end,
                        Set=function(_,v) local kc=v~="None" and Enum.KeyCode[v] or nil o:Set(kc) end
                    })
                end
                return o
            end

            -- ── Slider ────────────────────────────────────────────────────────
            -- FIX: drag usa connections limpas; nao trava mais
            function Sec:AddSlider(c)
                c = c or {}
                local mn    = c.Min     or 0
                local mx    = c.Max     or 100
                local def   = c.Default or mn
                local cb    = c.Callback or function() end
                local sfx   = c.Suffix   or ""
                local isInt = c.Integer  or false

                iOrd = iOrd + 1
                local row = U.New("Frame",{BackgroundTransparency=1,Size=UDim2.new(1,0,0,48),LayoutOrder=iOrd,Parent=card})
                U.New("TextLabel",{BackgroundTransparency=1,Position=UDim2.new(0,0,0,4),Size=UDim2.new(0.6,0,0,14),Text=c.Name or "Slider",TextColor3=T.TxtPri,Font=T.FntBody,TextSize=10,TextXAlignment=Enum.TextXAlignment.Left,Parent=row})
                local vLbl = U.New("TextLabel",{BackgroundTransparency=1,Position=UDim2.new(0.6,0,0,4),Size=UDim2.new(0.4,-2,0,14),Text=tostring(def)..sfx,TextColor3=T.RedLight,Font=T.FntMono,TextSize=9,TextXAlignment=Enum.TextXAlignment.Right,Parent=row})

                local track = U.New("Frame",{BackgroundColor3=T.Input,Position=UDim2.new(0,0,0,28),Size=UDim2.new(1,0,0,6),Parent=row})
                U.Corner(track,999)

                local pct0  = (mx~=mn) and (def-mn)/(mx-mn) or 0
                local fillB = U.New("Frame",{BackgroundColor3=T.Red,Size=UDim2.new(pct0,0,1,0),Parent=track})
                U.Corner(fillB,999)
                local thumb = U.New("Frame",{BackgroundColor3=Color3.new(1,1,1),AnchorPoint=Vector2.new(0.5,0.5),Position=UDim2.new(pct0,0,0.5,0),Size=UDim2.new(0,12,0,12),ZIndex=4,Parent=track})
                U.Corner(thumb,999) U.Stroke(thumb,T.Red,1.5,0)

                local val  = def
                local drag = false

                local function UpdSlider(v)
                    v = math.clamp(v, mn, mx)
                    if isInt then v = math.round(v) end
                    val = v
                    local p = (mx~=mn) and (v-mn)/(mx-mn) or 0
                    fillB.Size           = UDim2.new(p,0,1,0)
                    thumb.Position       = UDim2.new(p,0,0.5,0)
                    vLbl.Text            = tostring(isInt and v or math.round(v*10)/10)..sfx
                    cb(v)
                end

                -- FIX: connections no UserInputService com variavel local; sem vazar
                local mvConn, edConn

                track.InputBegan:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1 then
                        drag = true
                        local p = math.clamp((i.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
                        UpdSlider(mn + (mx-mn)*p)
                    end
                end)

                mvConn = UserInputService.InputChanged:Connect(function(i)
                    if drag and i.UserInputType == Enum.UserInputType.MouseMovement then
                        local p = math.clamp((i.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
                        UpdSlider(mn + (mx-mn)*p)
                    end
                end)

                edConn = UserInputService.InputEnded:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1 then
                        drag = false
                    end
                end)

                -- FIX: limpa connections quando o card for destruido
                card.AncestryChanged:Connect(function()
                    if not card.Parent then
                        if mvConn then mvConn:Disconnect() mvConn=nil end
                        if edConn then edConn:Disconnect() edConn=nil end
                    end
                end)

                local o = {}
                function o:Set(v) UpdSlider(v) end
                function o:Get() return val end
                if c.Name then ConfigSystem:Register(c.Name, o) end
                return o
            end

            -- ── Button ────────────────────────────────────────────────────────
            function Sec:AddButton(c)
                c = c or {} iOrd = iOrd + 1
                local rH  = c.Description and 52 or 34
                local row = U.New("Frame",{BackgroundTransparency=1,Size=UDim2.new(1,0,0,rH),LayoutOrder=iOrd,Parent=card})
                local b   = U.New("TextButton",{
                    BackgroundColor3=T.Elem, Position=UDim2.new(0,0,0,c.Description and 4 or 5),
                    Size=UDim2.new(1,0,0,24), Text="", ClipsDescendants=true, Parent=row
                })
                U.Corner(b,6) U.Stroke(b,T.BrdCard,1,0)
                U.New("TextLabel",{BackgroundTransparency=1,Size=UDim2.new(1,0,1,0),Text=c.Name or "Button",TextColor3=T.RedLight,Font=T.FntSemi,TextSize=10,Parent=b})
                if c.Description then
                    U.New("TextLabel",{BackgroundTransparency=1,Position=UDim2.new(0,0,0,30),Size=UDim2.new(1,0,0,14),Text=c.Description,TextColor3=T.TxtMute,Font=T.FntMono,TextSize=8,TextXAlignment=Enum.TextXAlignment.Center,Parent=row})
                end
                b.MouseEnter:Connect(function() U.Tw(b,{BackgroundColor3=T.RedDark},0.12) end)
                b.MouseLeave:Connect(function() U.Tw(b,{BackgroundColor3=T.Elem},0.12) end)
                b.MouseButton1Click:Connect(function()
                    U.Ripple(b,Mouse.X,Mouse.Y)
                    U.Tw(b,{BackgroundColor3=T.Red},0.06) task.wait(0.09) U.Tw(b,{BackgroundColor3=T.Elem},0.25)
                    ;(c.Callback or function()end)()
                end)
            end

            -- ── Dropdown ──────────────────────────────────────────────────────
            -- FIX: fecha ao clicar fora via UserInputService
            function Sec:AddDropdown(c)
                c = c or {}
                local row  = Row(c.Name or "Dropdown", 34)
                local opts = c.Options or {}
                local sel  = c.Default or opts[1]
                local cb   = c.Callback or function() end
                local open = false

                local db = U.New("TextButton",{
                    BackgroundColor3=T.Input, Position=UDim2.new(0.42,0,0.5,-11),
                    Size=UDim2.new(0.58,-2,0,22), Text="", ClipsDescendants=false, Parent=row
                })
                U.Corner(db,5) U.Stroke(db,T.BrdElem,1,0)

                local selLbl = U.New("TextLabel",{BackgroundTransparency=1,Position=UDim2.new(0,7,0,0),Size=UDim2.new(1,-22,1,0),Text=tostring(sel or ""),TextColor3=T.TxtPri,Font=T.FntBody,TextSize=9,TextXAlignment=Enum.TextXAlignment.Left,Parent=db})
                local chev   = U.New("TextLabel",{BackgroundTransparency=1,Position=UDim2.new(1,-16,0.5,-7),Size=UDim2.new(0,12,0,14),Text="v",TextColor3=T.RedLight,Font=T.FntBold,TextSize=9,Parent=db})

                local dl = U.New("Frame",{
                    BackgroundColor3=T.Input, BackgroundTransparency=0.06,
                    Position=UDim2.new(0,0,1,4), Size=UDim2.new(1,0,0,0),
                    ZIndex=100, ClipsDescendants=true, Visible=false, Parent=db
                })
                U.Corner(dl,6) U.Stroke(dl,T.BrdCard,1,0)
                U.New("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Parent=dl})

                for i, opt in ipairs(opts) do
                    local ob = U.New("TextButton",{
                        BackgroundColor3=T.Elem, BackgroundTransparency=(opt==sel) and 0.4 or 1,
                        Size=UDim2.new(1,0,0,26), Text="", LayoutOrder=i, ZIndex=101, Parent=dl
                    })
                    U.New("TextLabel",{BackgroundTransparency=1,Position=UDim2.new(0,9,0,0),Size=UDim2.new(1,-9,1,0),Text=tostring(opt),TextColor3=(opt==sel) and T.RedLight or T.TxtPri,Font=T.FntBody,TextSize=9,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=102,Parent=ob})
                    ob.MouseEnter:Connect(function() U.Tw(ob,{BackgroundTransparency=0.5,BackgroundColor3=T.Elem},0.1) end)
                    ob.MouseLeave:Connect(function() U.Tw(ob,{BackgroundTransparency=opt==sel and 0.4 or 1},0.1) end)
                    ob.MouseButton1Click:Connect(function()
                        sel=opt selLbl.Text=tostring(opt)
                        open=false
                        U.Tw(chev,{Rotation=0},0.15)
                        U.Tw(dl,{Size=UDim2.new(1,0,0,0)},0.18)
                        task.wait(0.2) dl.Visible=false
                        cb(sel)
                    end)
                end

                local th = #opts * 26

                local function OpenDropdown()
                    open=true dl.Visible=true dl.Size=UDim2.new(1,0,0,0)
                    U.Tw(dl,{Size=UDim2.new(1,0,0,th)},0.25,Enum.EasingStyle.Back)
                    U.Tw(chev,{Rotation=180},0.18)
                end
                local function CloseDropdown()
                    open=false
                    U.Tw(chev,{Rotation=0},0.15)
                    U.Tw(dl,{Size=UDim2.new(1,0,0,0)},0.18)
                    task.wait(0.2) if dl and dl.Parent then dl.Visible=false end
                end

                db.MouseButton1Click:Connect(function()
                    if open then CloseDropdown() else OpenDropdown() end
                end)

                -- FIX: fecha ao clicar fora
                UserInputService.InputBegan:Connect(function(i)
                    if open and i.UserInputType == Enum.UserInputType.MouseButton1 then
                        -- checar se o click foi fora do dropdown
                        local mp = i.Position
                        local dbPos  = db.AbsolutePosition
                        local dbSize = db.AbsoluteSize
                        local dlPos  = dl.AbsolutePosition
                        local dlSize = dl.AbsoluteSize
                        local inDb = mp.X>=dbPos.X and mp.X<=dbPos.X+dbSize.X and mp.Y>=dbPos.Y and mp.Y<=dbPos.Y+dbSize.Y
                        local inDl = mp.X>=dlPos.X and mp.X<=dlPos.X+dlSize.X and mp.Y>=dlPos.Y and mp.Y<=dlPos.Y+dlSize.Y
                        if not inDb and not inDl then
                            task.defer(CloseDropdown)
                        end
                    end
                end)

                local o = {}
                function o:Set(v) sel=v selLbl.Text=tostring(v) end
                function o:Get() return sel end
                if c.Name then ConfigSystem:Register(c.Name, o) end
                return o
            end

            -- ── TextBox ───────────────────────────────────────────────────────
            function Sec:AddTextBox(c)
                c = c or {}
                local row     = Row(c.Name or "Input", 34)
                local cb      = c.Callback  or function() end
                local numOnly = c.NumberOnly or false

                local box = U.New("TextBox",{
                    BackgroundColor3=T.Input, Position=UDim2.new(0.42,0,0.5,-11),
                    Size=UDim2.new(0.58,-2,0,22), Text=c.Default or "",
                    PlaceholderText=c.Placeholder or "...",
                    TextColor3=T.TxtPri, PlaceholderColor3=T.TxtMute,
                    Font=T.FntMono, TextSize=9, ClearTextOnFocus=false, Parent=row
                })
                U.Corner(box,5)
                local bstr = U.Stroke(box,T.BrdElem,1,0)

                box.Focused:Connect(function()
                    U.Tw(bstr,{Color=T.Red,Transparency=0.1},0.15)
                    U.Tw(box,{BackgroundColor3=T.RedDark},0.15)
                end)
                box.FocusLost:Connect(function(enter)
                    U.Tw(bstr,{Color=T.BrdElem,Transparency=0},0.15)
                    U.Tw(box,{BackgroundColor3=T.Input},0.15)
                    if numOnly and not tonumber(box.Text) then box.Text="" end
                    if enter then cb(box.Text) end
                end)
                box:GetPropertyChangedSignal("Text"):Connect(function()
                    if numOnly then box.Text = box.Text:gsub("[^%d%.%-]","") end
                end)

                local o = {}
                function o:Set(v) box.Text=tostring(v) end
                function o:Get() return box.Text end
                return o
            end

            -- ── Label ─────────────────────────────────────────────────────────
            function Sec:AddLabel(text)
                iOrd = iOrd + 1
                local r = U.New("Frame",{BackgroundTransparency=1,Size=UDim2.new(1,0,0,22),LayoutOrder=iOrd,Parent=card})
                U.New("TextLabel",{BackgroundTransparency=1,Position=UDim2.new(0,0,0,0),Size=UDim2.new(1,0,1,0),Text=text,TextColor3=T.TxtSec,Font=T.FntMono,TextSize=9,TextXAlignment=Enum.TextXAlignment.Left,TextWrapped=true,Parent=r})
            end

            -- ── Separator ─────────────────────────────────────────────────────
            function Sec:AddSeparator(lbl)
                iOrd = iOrd + 1
                local r = U.New("Frame",{BackgroundTransparency=1,Size=UDim2.new(1,0,0,18),LayoutOrder=iOrd,Parent=card})
                U.New("Frame",{BackgroundColor3=T.BrdCard,AnchorPoint=Vector2.new(0,0.5),Position=UDim2.new(0,0,0.5,0),Size=UDim2.new(1,0,0,1),Parent=r})
                if lbl then
                    local lb = U.New("Frame",{BackgroundColor3=T.Card,AnchorPoint=Vector2.new(0,0.5),Position=UDim2.new(0,6,0.5,0),Size=UDim2.new(0,0,0,12),AutomaticSize=Enum.AutomaticSize.X,Parent=r})
                    U.Pad(lb,0,4,0,4)
                    U.New("TextLabel",{BackgroundTransparency=1,Size=UDim2.new(0,0,1,0),AutomaticSize=Enum.AutomaticSize.X,Text=lbl,TextColor3=T.RedMute,Font=T.FntMono,TextSize=7,Parent=lb})
                end
            end

            return Sec
        end

        return Tab
    end

    -- animacao de abertura
    win.Size = UDim2.new(0,winW,0,0)
    task.wait(0.05)
    U.Tw(win,{Size=UDim2.new(0,winW,0,winH)},0.42,Enum.EasingStyle.Back)

    return Win
end

return BarbiUI
