-- ── Utilities ─────────────────────────────────────────────────────────────────
local U = {}

function U.Tw(obj, props, t, sty, dir)
    if not obj or not obj.Parent then return end
    pcall(function()
        TweenService:Create(
            obj,
            TweenInfo.new(t or 0.25, sty or Enum.EasingStyle.Quart, dir or Enum.EasingDirection.Out),
            props
        ):Play()
    end)
end

function U.New(cls, props)
    local ok, obj = pcall(Instance.new, cls)
    if not ok then return nil end
    pcall(function() if obj:IsA("GuiObject") then obj.BorderSizePixel = 0 end end)
    for k, v in pairs(props or {}) do
        if k ~= "Parent" then pcall(function() obj[k] = v end) end
    end
    if props and props.Parent then pcall(function() obj.Parent = props.Parent end) end
    return obj
end

function U.Corner(p, r)   return U.New("UICorner",  {CornerRadius=UDim.new(0,r or 8), Parent=p}) end
function U.Stroke(p,c,th,tr) return U.New("UIStroke",{Color=c, Thickness=th or 1, Transparency=tr or 0, Parent=p}) end
function U.Pad(p,t,r,b,l)
    return U.New("UIPadding",{
        PaddingTop=UDim.new(0,t or 8), PaddingRight=UDim.new(0,r or 8),
        PaddingBottom=UDim.new(0,b or 8), PaddingLeft=UDim.new(0,l or 8), Parent=p
    })
end

function U.Ripple(btn, x, y)
    if not btn or not btn.AbsolutePosition then return end
    local r = U.New("Frame",{
        BackgroundColor3=Color3.new(1,1,1), BackgroundTransparency=0.82,
        Position=UDim2.new(0,x-btn.AbsolutePosition.X-8,0,y-btn.AbsolutePosition.Y-8),
        Size=UDim2.new(0,16,0,16), ZIndex=(btn.ZIndex or 1)+5, ClipsDescendants=true, Parent=btn
    })
    if r then
        U.Corner(r,999)
        local s = btn.AbsoluteSize.X * 2.5
        U.Tw(r,{Size=UDim2.new(0,s,0,s),Position=UDim2.new(0.5,-s/2,0.5,-s/2),BackgroundTransparency=1},0.5)
        task.delay(0.55, function() if r and r.Parent then r:Destroy() end end)
    end
end

function U.GetTime()
    local ok,t = pcall(os.time)
    if not ok then return "00:00:00" end
    local ok2,s = pcall(os.date,"%H:%M:%S",t)
    return ok2 and s or "00:00:00"
end

function U.PulseDot(dot)
    task.spawn(function()
        while dot and dot.Parent do
            U.Tw(dot,{BackgroundTransparency=0.7, Size=UDim2.new(0,3,0,3)},1.2) task.wait(1.2)
            U.Tw(dot,{BackgroundTransparency=0,   Size=UDim2.new(0,5,0,5)},1.2) task.wait(1.2)
        end
    end)
end

-- ── Config System ─────────────────────────────────────────────────────────────
local ConfigSystem = { _toggles = {} }

function ConfigSystem:Register(name, obj) self._toggles[name] = obj end

function ConfigSystem:Save(cfgName)
    if not cfgName or cfgName == "" then return false end
    local data = {}
    for name, obj in pairs(self._toggles) do pcall(function() data[name] = obj:Get() end) end
    local ok = pcall(function()
        if not _if("BarbiUI") then _mf("BarbiUI") end
        _wf("BarbiUI/"..cfgName..".json", HttpService:JSONEncode(data))
    end)
    return ok
end

function ConfigSystem:Load(cfgName)
    if not cfgName or cfgName == "" then return false end
    local ok = pcall(function()
        local data = HttpService:JSONDecode(_rf("BarbiUI/"..cfgName..".json"))
        for name, val in pairs(data) do
            if self._toggles[name] then self._toggles[name]:Set(val, false) end
        end
    end)
    return ok
end

function ConfigSystem:List()
    local list = {}
    pcall(function()
        if not _if("BarbiUI") then _mf("BarbiUI") return end
        for _, f in ipairs(_lf("BarbiUI")) do
            local n = f:match("([^/\\]+)%.json$")
            if n then table.insert(list, n) end
        end
    end)
    return list
end

