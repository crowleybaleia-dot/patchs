        BackgroundTransparency=1, Size=UDim2.new(1,0,1,0),
        ClipsDescendants=true, ZIndex=2, Parent=win
    })
    U.Corner(clipFrame,10)

    -- bg fill
    U.New("Frame",{BackgroundColor3=T.WinBg,Size=UDim2.new(1,0,1,0),ZIndex=0,Parent=clipFrame})

    -- ── Topbar ────────────────────────────────────────────────────────────────
    local tb = U.New("Frame",{
        BackgroundColor3=T.TopBar, Size=UDim2.new(1,0,0,titleH),
        ZIndex=10, ClipsDescendants=false, Parent=clipFrame
    })
    U.New("Frame",{BackgroundColor3=T.BrdWin,Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,1,-1),ZIndex=11,Parent=tb})

    -- logo
    local logoF = U.New("Frame",{
        BackgroundColor3=T.RedDark, Size=UDim2.new(0,20,0,20),
        Position=UDim2.new(0,10,0.5,-10), ZIndex=12, Parent=tb
    })
    U.Corner(logoF,5) U.Stroke(logoF,T.Red,1,0.4)
    U.New("TextLabel",{BackgroundTransparency=1,Size=UDim2.new(1,0,1,0),Text="B",TextColor3=T.RedLight,Font=T.FntBold,TextSize=11,ZIndex=13,Parent=logoF})

    -- titulo
    U.New("TextLabel",{
        BackgroundTransparency=1, Position=UDim2.new(0,36,0.5,-7),
        Size=UDim2.new(0,120,0,14), Text=string.upper(title),
        TextColor3=T.TxtPri, Font=T.FntSemi, TextSize=11,
        TextXAlignment=Enum.TextXAlignment.Left, ZIndex=11, Parent=tb
    })

    -- relogio
    local clk = U.New("TextLabel",{
        BackgroundTransparency=1, Position=UDim2.new(0.5,-30,0.5,-6),
        Size=UDim2.new(0,60,0,12), Text=U.GetTime(),
        TextColor3=T.TxtMute, Font=T.FntMono, TextSize=8,
        TextXAlignment=Enum.TextXAlignment.Center, ZIndex=11, Parent=tb
    })
    task.spawn(function() while clk and clk.Parent do clk.Text=U.GetTime() task.wait(1) end end)

    -- botoes de controle (x, -)
    local function CtrlBtn(sym, hov, xOff, cb)
        local b = U.New("TextButton",{
            BackgroundColor3=Color3.fromRGB(25,18,18), BackgroundTransparency=0,
            Position=UDim2.new(1,xOff,0.5,-8), Size=UDim2.new(0,16,0,16),
            Text=sym, TextColor3=T.TxtMute, Font=T.FntBold, TextSize=9,
            ZIndex=15, Parent=tb
        })
        U.Corner(b,999)
        b.MouseEnter:Connect(function() U.Tw(b,{BackgroundColor3=hov,TextColor3=Color3.new(1,1,1)},0.12) end)
        b.MouseLeave:Connect(function() U.Tw(b,{BackgroundColor3=Color3.fromRGB(25,18,18),TextColor3=T.TxtMute},0.12) end)
        b.MouseButton1Click:Connect(cb)
        return b
    end

    CtrlBtn("×", T.Error, -24, function()
        U.Tw(win,{Size=UDim2.new(0,winW,0,0),BackgroundTransparency=1},0.28,Enum.EasingStyle.Back,Enum.EasingDirection.In)
        task.wait(0.32) sg:Destroy()
    end)

    -- FIX: minimizar usa flag pra guardar tamanho correto
    local minimized = false
    local lastH = winH
    CtrlBtn("−", T.Warning, -46, function()
        minimized = not minimized
        if minimized then
            lastH = win.Size.Y.Offset > titleH and win.Size.Y.Offset or winH
            U.Tw(win,{Size=UDim2.new(0,winW,0,titleH)},0.25,Enum.EasingStyle.Quart)
        else
            U.Tw(win,{Size=UDim2.new(0,winW,0,lastH)},0.35,Enum.EasingStyle.Back)
        end
    end)

    -- drag
    local dragging, dStart, dSPos
    tb.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging=true dStart=i.Position dSPos=win.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
            local d = i.Position - dStart
            win.Position = UDim2.new(dSPos.X.Scale, dSPos.X.Offset+d.X, dSPos.Y.Scale, dSPos.Y.Offset+d.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging=false end
    end)

    -- toggle visibilidade
    local vis = true
    local currentKey = key
    local function SetUIKey(k) currentKey = k end

    UserInputService.InputBegan:Connect(function(i, gp)
        if gp then return end
        if i.KeyCode == currentKey then
            vis = not vis
            if vis then
                win.Visible = true
                win.Size = UDim2.new(0,winW,0,titleH)
                U.Tw(win,{Size=UDim2.new(0,winW,0,winH)},0.38,Enum.EasingStyle.Back)
            else
                U.Tw(win,{Size=UDim2.new(0,winW,0,titleH)},0.25,Enum.EasingStyle.Quart,Enum.EasingDirection.In)
                task.wait(0.3) win.Visible = false
            end
        end
    end)

    -- ── Tab Bar (estilo Linoria) ───────────────────────────────────────────────
    local tabBar = U.New("Frame",{
        BackgroundColor3=T.TabBar, Size=UDim2.new(1,0,0,tabH),
        Position=UDim2.new(0,0,0,titleH), ZIndex=9, ClipsDescendants=true, Parent=clipFrame
    })
    U.New("Frame",{BackgroundColor3=T.BrdWin,Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,1,-1),ZIndex=10,Parent=tabBar})

    local tabBtnList = U.New("UIListLayout",{
        FillDirection=Enum.FillDirection.Horizontal,
        SortOrder=Enum.SortOrder.LayoutOrder,
        Padding=UDim.new(0,0), Parent=tabBar
    })
    U.Pad(tabBar,0,0,0,8)

    -- ── Content area ──────────────────────────────────────────────────────────
    local contentY = titleH + tabH
    local contentArea = U.New("Frame",{
        BackgroundTransparency=1,
        Position=UDim2.new(0,0,0,contentY),
        Size=UDim2.new(1,0,1,-contentY),
        ClipsDescendants=true, Parent=clipFrame
    })

    local Win = {_tabs={}, _btns={}, _active=nil, _ord=0}

    local function ActivateTab(btn, underline, page)
        for _, it in ipairs(Win._btns) do
            U.Tw(it.btn,{BackgroundTransparency=1},0.15)
            U.Tw(it.lbl,{TextColor3=T.TxtSec},0.15)
            if it.ul then U.Tw(it.ul,{BackgroundTransparency=1},0.15) end
        end
        for _, pg in ipairs(Win._tabs) do pg.Visible = false end
        U.Tw(btn,{BackgroundTransparency=0.88,BackgroundColor3=T.Elem},0.15)
        U.Tw(btn:FindFirstChildWhichIsA("TextLabel") or btn,{TextColor3=T.TxtPri},0.15)
        if underline then U.Tw(underline,{BackgroundTransparency=0},0.15) end
        page.Visible = true
        Win._active = page
    end

    local function MakeTabBtn(name, badge, lo)
        Win._ord = Win._ord + 1
        local btn = U.New("TextButton",{
            BackgroundColor3=T.Elem, BackgroundTransparency=1,
            Size=UDim2.new(0,0,1,0), AutomaticSize=Enum.AutomaticSize.X,
            Text="", LayoutOrder=lo or Win._ord,
            ClipsDescendants=false, Parent=tabBar
        })
        U.Pad(btn,0,16,0,16)
        local lbl = U.New("TextLabel",{
            BackgroundTransparency=1, Size=UDim2.new(0,0,1,0),
            AutomaticSize=Enum.AutomaticSize.X, Text=name,
            TextColor3=T.TxtSec, Font=T.FntSemi, TextSize=11,
            ZIndex=2, Parent=btn
        })
        -- underline indicador
        local ul = U.New("Frame",{
            BackgroundColor3=T.Red, Size=UDim2.new(1,0,0,2),
            AnchorPoint=Vector2.new(0,1), Position=UDim2.new(0,0,1,0),
            BackgroundTransparency=1, ZIndex=3, Parent=btn
        })
        -- badge
        if badge then
            local bf = U.New("Frame",{
                BackgroundColor3=T.RedDark, Position=UDim2.new(1,-4,0.5,-9),
                Size=UDim2.new(0,16,0,14), ZIndex=3, Parent=btn
            })
            U.Corner(bf,4)
            U.New("TextLabel",{BackgroundTransparency=1,Size=UDim2.new(1,0,1,0),Text=tostring(badge),TextColor3=T.RedLight,Font=T.FntBold,TextSize=7,ZIndex=4,Parent=bf})
        end

        btn.MouseEnter:Connect(function()
            if Win._active ~= nil then
                local isActive = false
                for _,it in ipairs(Win._btns) do if it.btn==btn and Win._tabs[_]==Win._active then isActive=true break end end
                -- verifica se esta ativo por outro meio
            end
            U.Tw(btn,{BackgroundTransparency=0.93,BackgroundColor3=T.Elem},0.12)
        end)
        btn.MouseLeave:Connect(function()
            local active = false
            for i,it in ipairs(Win._btns) do if it.btn==btn and Win._tabs[i]==Win._active then active=true break end end
            if not active then U.Tw(btn,{BackgroundTransparency=1},0.12) end
        end)

        return btn, lbl, ul
    end

    local function MakePage()
        local page = U.New("ScrollingFrame",{
            BackgroundTransparency=1, Size=UDim2.new(1,0,1,0),
            ScrollBarThickness=2, ScrollBarImageColor3=T.RedMute,
            CanvasSize=UDim2.new(0,0,0,0), AutomaticCanvasSize=Enum.AutomaticSize.Y,
            Visible=false, Parent=contentArea
        })
        U.Pad(page,14,14,14,14)
        U.New("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,10),Parent=page})
