    -- ── AddTab ────────────────────────────────────────────────────────────────
    function Win:AddTab(tc)
        tc = tc or {}
        local name  = tc.Name  or ("Tab "..#self._tabs+1)
        local badge = tc.Badge

        local btn, lbl, ul = MakeTabBtn(name, badge)
        local page = MakePage()

        -- header da page
        local ph = U.New("Frame",{BackgroundTransparency=1,Size=UDim2.new(1,0,0,28),LayoutOrder=0,Parent=page})
        U.New("TextLabel",{BackgroundTransparency=1,Size=UDim2.new(0.5,0,1,0),Text=name,TextColor3=T.TxtPri,Font=T.FntSemi,TextSize=14,TextXAlignment=Enum.TextXAlignment.Left,Parent=ph})
