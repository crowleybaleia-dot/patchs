GoToNPC = function()
    if questRunning then return end
    questRunning = true
    TrackSettings.Enabled = false
    RifleSettings.Enabled = false
    RifleSettings.ShowESP = false
    StopTrack() StopFloat() StopNoclip()
    StartQuestFloat(QuestSettings.NpcPosition.Y)
    questMoveConn = RunService.Heartbeat:Connect(function()
        if not questRunning then StopQuestMove() StopQuestFloat() return end
        local r = GetRoot()
        if not r then return end
        local now = tick()
        if now - questLastStam > TrackSettings.StamInterval then questLastStam = now DashBypass() end
        local myPos     = r.Position
        local npcPos    = QuestSettings.NpcPosition
        local horizDist = Vector3.new(myPos.X - npcPos.X, 0, myPos.Z - npcPos.Z).Magnitude
        if horizDist <= QuestSettings.ArrivalDist then
            r.AssemblyLinearVelocity = Vector3.zero
            StopQuestMove() StopQuestFloat() PurgePhysics()
            task.spawn(TakeQuest)
            return
        end
        local dir = Vector3.new(npcPos.X - myPos.X, 0, npcPos.Z - myPos.Z).Unit
        r.AssemblyLinearVelocity = Vector3.new(
            dir.X * QuestSettings.FlySpeed,
            r.AssemblyLinearVelocity.Y,
            dir.Z * QuestSettings.FlySpeed
        )
    end)
end

local function AdvanceToNext(arrivedWp)
    local d = arrivedWp and (arrivedWp.delay or 0) or 0
    if d > 0 then
    StopFloat() StopTrack() PurgePhysics()
    local elapsed = 0
    local wp = Waypoints[currentWaypointIndex]
    while elapsed < d do
        task.wait(0.5)
        elapsed = elapsed + 0.5
        local root = GetRoot()
        if not root then break end
        root.CFrame = CFrame.new(wp.pos)
        DashBypass()
    end
end
    currentWaypointIndex = currentWaypointIndex + 1
    if currentWaypointIndex > #Waypoints then
        waypointsDone = true TrackSettings.Enabled = false isLanding = false
        StopNoclip() PurgePhysics()
        local lvl = GetCurrentLevel()
        if lvl and lvl >= QuestSettings.MinLevel then
            questEnabled = true GoToNPC()
        else
            questEnabled = true
            local levelConn
            levelConn = RunService.Heartbeat:Connect(function()
                if not questEnabled then levelConn:Disconnect() return end
                local l = GetCurrentLevel()
                if l and l >= QuestSettings.MinLevel then levelConn:Disconnect() GoToNPC() end
            end)
        end
        return
    end
    local next = Waypoints[currentWaypointIndex]
    isGroundMode = not next.fly
    if next.fly then
        local root = GetRoot()
        if root then
            root.CFrame = CFrame.new(root.Position.X, TrackSettings.TravelHeight, root.Position.Z)
            DashBypass()
        end
        task.wait(0.3)
    end
    StartFloat() StartTrack()
end

StartTrack = function()
    if trackConn then trackConn:Disconnect() end
    trackConn = RunService.Heartbeat:Connect(function()
        if not TrackSettings.Enabled then return end
        if isLanding then return end
        local root = GetRoot()
        if not root then return end
        local now = tick()
        if now - lastStam > TrackSettings.StamInterval then lastStam = now DashBypass() end
        if waypointsDone then root.AssemblyLinearVelocity = Vector3.zero return end
        local wp = Waypoints[currentWaypointIndex]
        if not wp then return end
        local myPos     = root.Position
        local horizDist = Vector3.new(myPos.X - wp.pos.X, 0, myPos.Z - wp.pos.Z).Magnitude
        if horizDist <= TrackSettings.ArrivalDist then
            root.AssemblyLinearVelocity = Vector3.zero
            StopTrack()
            local arrivedWp = wp
            if wp.fly then
                isLanding = true
                task.spawn(function()
                    SafeLanding(wp.pos, function()
                        isLanding = false
                        AdvanceToNext(arrivedWp)
                    end)
                end)
            else
                task.spawn(function() AdvanceToNext(arrivedWp) end)
            end
            return
        end
        local speed = isGroundMode and TrackSettings.GroundSpeed or TrackSettings.FlySpeed
        local dir   = Vector3.new(wp.pos.X - myPos.X, 0, wp.pos.Z - myPos.Z).Unit
        if isGroundMode then
            local diffY = wp.pos.Y - myPos.Y
            root.AssemblyLinearVelocity = Vector3.new(
                dir.X * speed, math.clamp(diffY * 10, -30, 30), dir.Z * speed
            )
        else
            root.AssemblyLinearVelocity = Vector3.new(
                dir.X * speed, root.AssemblyLinearVelocity.Y, dir.Z * speed
            )
        end
    end)
end

local function EnableAll()
    currentWaypointIndex  = 1
    waypointsDone         = false
    isLanding             = false
    questEnabled          = false
    questRunning          = false
    questDone             = false
    local first           = Waypoints[1]
    isGroundMode          = not first.fly
    TrackSettings.Enabled = true
    RifleSettings.Enabled = true
    RifleSettings.ShowESP = true
    StartNoclip()
    if first.fly then
        local root = GetRoot()
        if root then
            root.CFrame = CFrame.new(root.Position.X, TrackSettings.TravelHeight, root.Position.Z)
            DashBypass()
        end
        task.wait(0.3)
    end
    StartFloat() StartTrack()
end

local function DisableAll()
    TrackSettings.Enabled = false
    RifleSettings.Enabled = false
    RifleSettings.ShowESP = false
    questEnabled          = false
    questRunning          = false
    questDone             = false
    isLanding             = false
    isGroundMode          = false
    if progressConn then progressConn:Disconnect() progressConn = nil end
    StopTrack() StopFloat() StopQuestMove() StopQuestFloat() StopNoclip() PurgePhysics()
end

