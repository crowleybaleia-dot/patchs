local function ESPFormatDist(d) return d >= 1000 and string.format("%.1f km", d/1000) or string.format("%d m", d) end
local function ESPGetSizeStep(d)
    for _, s in ipairs(ESPConfig.SizeSteps) do if d <= s[1] then return s[2], s[3], s[4] end end
    local s = ESPConfig.SizeSteps[#ESPConfig.SizeSteps] return s[2], s[3], s[4]
