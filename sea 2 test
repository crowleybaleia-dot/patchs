local antiAfkLoop     = nil

local function StartAntiAFK()
    pcall(function()
        for _, conn in pairs(getconnections(Players.LocalPlayer.Idled)) do conn:Disable() end
    end)
    if antiAfkLoop then antiAfkLoop:Disconnect() end
    antiAfkLoop = RunService.Heartbeat:Connect(function()
        if not AntiAFKSettings.Enabled then return end
    end)
    task.spawn(function()
        while AntiAFKSettings.Enabled do
            task.wait(25)
            if not AntiAFKSettings.Enabled then break end
            local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if root then root.CFrame = root.CFrame * CFrame.Angles(0, math.rad(1), 0) end
        end
    end)
end

local function StopAntiAFK()
    AntiAFKSettings.Enabled = false
    pcall(function()
        for _, conn in pairs(getconnections(Players.LocalPlayer.Idled)) do conn:Enable() end
    end)
    if antiAfkLoop then antiAfkLoop:Disconnect() antiAfkLoop = nil end
end

