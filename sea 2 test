local currentAmmo      = RifleSettings.MaxAmmo
local isReloading      = false
local lastShot         = 0
local targetCache      = nil
local lastTargetUpdate = 0

local function AutoEquipRifle()
    local char = LocalPlayer.Character
    if not char then return false end
    if char:FindFirstChild("Rifle") then return true end
    local rifle = LocalPlayer.Backpack and LocalPlayer.Backpack:FindFirstChild("Rifle")
    if not rifle then return false end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return false end
    local ok = pcall(function() hum:EquipTool(rifle) end)
    if ok then task.wait(0.2) end
    return ok
end

local function GetRootPart()
    return LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
end

local function IsValidTarget(npc)
    if not npc or not npc.Parent then return false end
    if RifleSettings.IgnoreForceField and npc:FindFirstChildWhichIsA("ForceField") then return false end
    local humanoid = npc:FindFirstChild("Humanoid")
    local root     = npc:FindFirstChild("HumanoidRootPart")
    if not humanoid or not root then return false end
    if humanoid.Health <= 0 then return false end
    return true
end

local function GetHeadPosition(npc)
    local head = npc:FindFirstChild("Head")
    if head and head:IsA("BasePart") then return head.Position end
    local root = npc:FindFirstChild("HumanoidRootPart")
    if root then return root.Position + Vector3.new(0, 1.5, 0) end
    return nil
end

local function FindBestTarget()
    local root = GetRootPart()
    if not root then return nil end
    local best, bestDist = nil, math.huge
    for _, npc in ipairs(Workspace.NPCs:GetChildren()) do
        if not IsValidTarget(npc) then continue end
        local npcRoot = npc:FindFirstChild("HumanoidRootPart")
        if not npcRoot then continue end
        local d = (root.Position - npcRoot.Position).Magnitude
        if d < RifleSettings.MinRange or d > RifleSettings.Range then continue end
        if d < bestDist then bestDist = d best = npc end
    end
    return best
end

local function UpdateTarget()
    local now = tick()
    if targetCache and IsValidTarget(targetCache) then
        if now - lastTargetUpdate < RifleSettings.UpdateRate then return targetCache end
    end
    targetCache = FindBestTarget() lastTargetUpdate = now
    return targetCache
end

local function ReloadRifle()
    if isReloading then return end
    isReloading = true
    task.spawn(function()
        local ok = pcall(function() gunFunctions:InvokeServer("reload", { Gun = "Rifle" }) end)
        if ok then currentAmmo = RifleSettings.MaxAmmo end
        task.wait(RifleSettings.ReloadTime)
        isReloading = false
    end)
end

local function ShootTarget(target)
    if not target or isReloading then return false end
    if not AutoEquipRifle() then return false end
    if currentAmmo <= 0 then if RifleSettings.AutoReload then ReloadRifle() end return false end
    local now = tick()
    if now - lastShot < RifleSettings.FireDelay then return false end
    local root = GetRootPart()
    if not root then return false end
    local targetPos = GetHeadPosition(target)
    if not targetPos then return false end
    local npcRoot = target:FindFirstChild("HumanoidRootPart")
    if not npcRoot then return false end
    if RifleSettings.UsePrediction then
        local vel = npcRoot.AssemblyLinearVelocity
        if vel.Magnitude > 2 then
            local d = (root.Position - targetPos).Magnitude
            targetPos = targetPos + vel * (d / RifleSettings.BulletSpeed) * RifleSettings.PredictionMultiplier
        end
    end
    local ok = pcall(function()
        GunManager:FireServer("fire", {
            Start = CFrame.lookAt(root.Position, targetPos),
            Gun = "Rifle", joe = "true", Position = targetPos,
        })
        currentAmmo = currentAmmo - 1
        lastShot    = now
    end)
    return ok
end

