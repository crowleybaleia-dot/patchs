local function checkExecutorSupport()
    local required = {
        run_on_actor    = run_on_actor,
        hookfunction    = hookfunction or hookfunc,
        hookmetamethod  = hookmetamethod,
        getnamecallmethod = getnamecallmethod,
        checkcaller     = checkcaller,
        getnilinstances = getnilinstances,
    }
    for name, func in pairs(required) do
        if not func then
            warn("Executor não suporta: " .. name)
            return false, name
        end
    end
    print("Executor suportado")
    return true
end

