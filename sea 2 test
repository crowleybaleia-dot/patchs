local Sea2Settings = {
    Enabled      = false,
    FlySpeed     = 135,
    TravelHeight = 900,
    FloatHeight  = 5,
    ArrivalDist  = 8,
    NoclipOn     = true,
    StamInterval = 0.3,
}

local sea2CurrentDestination     = nil
local sea2CurrentDestinationName = nil
local sea2WaypointsDone          = false
local sea2IsLanding              = false
local sea2LastStam               = 0
local sea2TrackConn              = nil
local sea2NoclipConn             = nil
local sea2FloatAtt               = nil
local sea2FloatLV                = nil
local sea2FloatConn              = nil

local function Sea2GetRoot()
    local c = LocalPlayer.Character
    return c and c:FindFirstChild("HumanoidRootPart")
end
local function Sea2GetHum()
    local c = LocalPlayer.Character
    return c and c:FindFirstChildOfClass("Humanoid")
end
local function Sea2DashBypass()
    pcall(function() TakeStam:FireServer(0.505, "dash") end)
end

local function Sea2StartNoclip()
    if sea2NoclipConn then sea2NoclipConn:Disconnect() end
    sea2NoclipConn = RunService.Stepped:Connect(function()
        if not Sea2Settings.NoclipOn then return end
        local c = LocalPlayer.Character
        if not c then return end
        for _, p in ipairs(c:GetDescendants()) do
            if p:IsA("BasePart") then p.CanCollide = false end
        end
    end)
end

local function Sea2StopNoclip()
    if sea2NoclipConn then sea2NoclipConn:Disconnect() sea2NoclipConn = nil end
    local c = LocalPlayer.Character
    if not c then return end
    for _, p in ipairs(c:GetDescendants()) do
        if p:IsA("BasePart") then p.CanCollide = true end
    end
end

local function Sea2StopFloat()
    if sea2FloatConn then sea2FloatConn:Disconnect() sea2FloatConn = nil end
    if sea2FloatLV  and sea2FloatLV.Parent  then sea2FloatLV:Destroy()  end ; sea2FloatLV  = nil
    if sea2FloatAtt and sea2FloatAtt.Parent then sea2FloatAtt:Destroy() end ; sea2FloatAtt = nil
end

local function Sea2StartFloat()
    Sea2StopFloat()
    local root = Sea2GetRoot()
    if not root then return end
    sea2FloatAtt        = Instance.new("Attachment")
    sea2FloatAtt.Name   = "Sea2FloatAtt"
    sea2FloatAtt.Parent = root
    sea2FloatLV                        = Instance.new("LinearVelocity")
    sea2FloatLV.Name                   = "Sea2FloatLV"
    sea2FloatLV.Attachment0            = sea2FloatAtt
    sea2FloatLV.VelocityConstraintMode = Enum.VelocityConstraintMode.Line
    sea2FloatLV.LineDirection          = Vector3.new(0, 1, 0)
    sea2FloatLV.LineVelocity           = 0
    sea2FloatLV.MaxForce               = 1e5
    sea2FloatLV.Parent                 = root
    sea2FloatConn = RunService.Heartbeat:Connect(function()
        if not Sea2Settings.Enabled then return end
        if sea2IsLanding then return end
        local r = Sea2GetRoot()
        if not r or not sea2FloatLV or not sea2FloatLV.Parent then return end
        sea2FloatLV.LineVelocity = math.clamp((Sea2Settings.TravelHeight - r.Position.Y) * 10, -150, 150)
    end)
end

local function Sea2FullCleanup()
    local root = Sea2GetRoot()
    local c    = LocalPlayer.Character
    Sea2StopFloat()
    Sea2StopNoclip()
    Sea2Settings.Enabled = false
    sea2IsLanding        = false
    sea2WaypointsDone    = false
    if not root or not c then return end
    for _, obj in ipairs(root:GetChildren()) do
        if obj:IsA("BodyMover") or obj:IsA("LinearVelocity")
        or obj:IsA("AngularVelocity") or obj:IsA("Attachment")
        or obj.Name == "Sea2FloatAtt" or obj.Name == "Sea2FloatLV" then
            obj:Destroy()
        end
    end
    root.AssemblyLinearVelocity  = Vector3.zero
    root.AssemblyAngularVelocity = Vector3.zero
    for _, p in ipairs(c:GetDescendants()) do
        if p:IsA("BasePart") then p.CanCollide = true p.Anchored = false end
    end
    local hum = Sea2GetHum()
    if hum then
        hum.PlatformStand = false
        hum.AutoRotate    = true
        pcall(function() hum:ChangeState(Enum.HumanoidStateType.Freefall) end)
    end
end

local sea2RayParams = RaycastParams.new()
sea2RayParams.FilterType = Enum.RaycastFilterType.Exclude

local function Sea2SafeLanding(wpPos, afterLand)
    local root = Sea2GetRoot()
    local c    = LocalPlayer.Character
    if not root or not c then return end
    sea2RayParams.FilterDescendantsInstances = { c }
    local ray = workspace:Raycast(
        Vector3.new(wpPos.X, Sea2Settings.TravelHeight, wpPos.Z),
        Vector3.new(0, -Sea2Settings.TravelHeight - 500, 0),
        sea2RayParams
    )
    local groundY = ray and ray.Position.Y or wpPos.Y
    local safePos = CFrame.new(wpPos.X, groundY + Sea2Settings.FloatHeight, wpPos.Z)
    root.Anchored = true
    root.AssemblyLinearVelocity  = Vector3.zero
    root.AssemblyAngularVelocity = Vector3.zero
    Sea2StopFloat()
    task.wait(0.1)
    c:PivotTo(safePos)
    Sea2DashBypass()
    task.wait(0.1)
    root.Anchored = false
    local hum = Sea2GetHum()
    if hum then hum:ChangeState(Enum.HumanoidStateType.Freefall) end
    task.wait(0.4)
    if afterLand then afterLand() end
end

local function Sea2StopTrack()
    if sea2TrackConn then sea2TrackConn:Disconnect() sea2TrackConn = nil end
    local root = Sea2GetRoot()
    if root then root.AssemblyLinearVelocity = Vector3.zero end
end

local function Sea2StartTrack()
    if sea2TrackConn then sea2TrackConn:Disconnect() end
    sea2TrackConn = RunService.Heartbeat:Connect(function()
        if not Sea2Settings.Enabled then return end
        if sea2IsLanding then return end
        local root = Sea2GetRoot()
        if not root then return end
        local now = tick()
        if now - sea2LastStam > Sea2Settings.StamInterval then
            sea2LastStam = now
            Sea2DashBypass()
        end
        if sea2WaypointsDone or not sea2CurrentDestination then
            root.AssemblyLinearVelocity = Vector3.zero
            return
        end
        local dest      = sea2CurrentDestination
        local myPos     = root.Position
        local horizDist = Vector3.new(myPos.X - dest.X, 0, myPos.Z - dest.Z).Magnitude
        if horizDist <= Sea2Settings.ArrivalDist then
            root.AssemblyLinearVelocity = Vector3.zero
            Sea2StopTrack()
            sea2IsLanding = true
            task.spawn(function()
                Sea2SafeLanding(dest, function()
                    sea2IsLanding     = false
                    sea2WaypointsDone = true
                    Sea2FullCleanup()
                    pcall(function()
                        BarbiUI:Notify({ Title="🏃 Sea 2 Travel", Message="Chegou em: " .. (sea2CurrentDestinationName or "?"), Type="success", Duration=4 })
                    end)
                end)
            end)
            return
        end
        local dir = Vector3.new(dest.X - myPos.X, 0, dest.Z - myPos.Z).Unit
        root.AssemblyLinearVelocity = Vector3.new(
            dir.X * Sea2Settings.FlySpeed,
            root.AssemblyLinearVelocity.Y,
            dir.Z * Sea2Settings.FlySpeed
        )
    end)
end

local function Sea2TravelTo(islandName)
    local dest = Islands_Sea2_New[islandName]
    if not dest then return end
    if Sea2Settings.Enabled then Sea2StopTrack() Sea2FullCleanup() task.wait(0.3) end
    sea2CurrentDestination     = dest
    sea2CurrentDestinationName = islandName
    sea2WaypointsDone          = false
    sea2IsLanding              = false
    Sea2Settings.Enabled       = true
    local root = Sea2GetRoot()
    if root then
        root.CFrame = CFrame.new(root.Position.X, Sea2Settings.TravelHeight, root.Position.Z)
    end
    Sea2DashBypass()
    Sea2StartNoclip()
    task.wait(0.2)
    Sea2StartFloat()
    Sea2StartTrack()
    pcall(function()
        BarbiUI:Notify({ Title="🏃 Sea 2 Travel", Message="Indo para: " .. islandName, Type="info", Duration=3 })
    end)
end

local function Sea2TravelDisable()
    Sea2StopTrack()
    Sea2FullCleanup()
    pcall(function()
        BarbiUI:Notify({ Title="🏃 Sea 2 Travel", Message="Viagem cancelada.", Type="warning", Duration=2 })
    end)
end

LocalPlayer.CharacterAdded:Connect(function()
    task.wait(1)
    if Sea2Settings.Enabled then
        Sea2StartNoclip()
        Sea2StartFloat()
        Sea2StartTrack()
    end
end)



