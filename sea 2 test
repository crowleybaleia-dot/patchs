-- Optimize Game------------------------------------- uma grande merda. remover isso antes do lançamento
local function OptimizeGame()
    local Lighting    = game:GetService("Lighting")
    local SoundService = game:GetService("SoundService")
    local Terrain     = Workspace:FindFirstChildOfClass("Terrain")
    local sethidden   = sethiddenproperty or set_hidden_property or set_hidden_prop

    Lighting.GlobalShadows            = false
    Lighting.FogEnd                   = 9e9
    Lighting.FogStart                 = 9e9
    Lighting.Brightness               = 2
    Lighting.ClockTime                = 14
    Lighting.GeographicLatitude       = 0
    Lighting.EnvironmentDiffuseScale  = 0
    Lighting.EnvironmentSpecularScale = 0
    Lighting.ShadowSoftness           = 0
    Lighting.ExposureCompensation     = 0
    Lighting.Ambient                  = Color3.fromRGB(178, 178, 178)
    Lighting.OutdoorAmbient           = Color3.fromRGB(178, 178, 178)

    pcall(function() sethidden(Lighting, "Technology",         2) end)
    pcall(function() sethidden(Lighting, "GlobalIllumination", 0) end)
    pcall(function() sethidden(Lighting, "LegacyOutlines",  false) end)
    pcall(function() sethidden(Lighting, "Outlines",        false) end)

    for _, fx in Lighting:GetChildren() do
        if fx:IsA("BlurEffect") or fx:IsA("BloomEffect") or fx:IsA("SunRaysEffect")
        or fx:IsA("ColorCorrectionEffect") or fx:IsA("DepthOfFieldEffect")
        or fx:IsA("Atmosphere") or fx:IsA("Clouds") or fx:IsA("Sky") then
            fx.Parent = nil
        end
    end

    if Terrain then
        Terrain.WaterWaveSize     = 0
        Terrain.WaterWaveSpeed    = 0
        Terrain.WaterReflectance  = 0
        Terrain.WaterTransparency = 1
        Terrain.WaterColor        = Color3.new(0.3, 0.3, 0.3)
        pcall(function() sethidden(Terrain, "Decoration", false) end)
        pcall(function() sethidden(Terrain, "GrassLength", 0)   end)
    end

    pcall(function() sethidden(Workspace, "InterpolationThrottling",         0) end)
    pcall(function() sethidden(Workspace, "PhysicsSteppingMethod",           0) end)
    pcall(function() sethidden(Workspace, "HumanoidOnlySetCollisionsOnStateChange", 2) end)
    pcall(function() sethidden(Workspace, "MeshPartHeadsAndAccessories",     1) end)
    pcall(function() sethidden(Workspace, "ClientAnimatorThrottling",        0) end)
    if Workspace.StreamingEnabled then
        pcall(function() sethidden(Workspace, "StreamingMinRadius",    16) end)
        pcall(function() sethidden(Workspace, "StreamingTargetRadius", 64) end)
    end

    pcall(function()
        SoundService.AmbientReverb   = Enum.ReverbType.NoReverb
        SoundService.DopplerScale    = 0
        SoundService.RolloffScale    = 0
        SoundService.VolumetricAudio = Enum.VolumetricAudio.Disabled
    end)

    local whitelist = { fallingParticle = true, Lines = true, Lines2 = true }
    local function inWhitelist(obj)
        if not obj then return true end
        if whitelist[obj.Name] then return true end
        local p = obj.Parent
        while p do
            if whitelist[p.Name] then return true end
            p = p.Parent
        end
        return false
    end

    for _, obj in Workspace:GetDescendants() do
        if not obj or not obj.Parent then continue end
        if inWhitelist(obj) then continue end
        local cn = obj.ClassName
        pcall(function()
            if cn == "ParticleEmitter" then
                obj.Enabled = false obj.Rate = 0 obj.Texture = ""
                obj.Lifetime = NumberRange.new(0) obj.Speed = NumberRange.new(0)
                obj.Size = NumberSequence.new(0) obj.Transparency = NumberSequence.new(1)
                obj.LightEmission = 0 obj.LightInfluence = 0 obj.Drag = 9999
                obj.Parent = nil
            elseif cn == "Trail" then
                obj.Enabled = false obj.Lifetime = 0 obj.Texture = ""
                obj.LightEmission = 0 obj.LightInfluence = 0
                obj.Transparency = NumberSequence.new(1) obj.MinLength = 9e9
                obj.Parent = nil
            elseif cn == "Beam" then
                obj.Enabled = false obj.Texture = "" obj.LightEmission = 0
                obj.LightInfluence = 0 obj.Transparency = NumberSequence.new(1)
                obj.Width0 = 0 obj.Width1 = 0 obj.Segments = 1
                obj.Parent = nil
            elseif cn == "Fire" or cn == "Smoke" or cn == "Sparkles" then
                obj.Enabled = false
                if cn == "Fire"  then obj.Size = 0 obj.Heat = 0 end
                if cn == "Smoke" then obj.Size = 0 obj.Opacity = 0 end
                obj.Parent = nil
            elseif cn == "Highlight" then
                obj.Enabled = false obj.FillTransparency = 1 obj.OutlineTransparency = 1
                obj.Parent = nil
            elseif cn == "Texture" or cn == "Decal" then
                obj.Texture = "" obj.Transparency = 1
                obj.Parent = nil
            elseif cn == "SurfaceAppearance" then
                obj.ColorMap = "" obj.MetalnessMap = "" obj.NormalMap = ""
                obj.RoughnessMap = "" obj.TexturePack = ""
                obj.Parent = nil
            elseif cn == "MeshPart" then
                obj.RenderFidelity = Enum.RenderFidelity.Performance
                obj.CastShadow = false obj.DoubleSided = false obj.Reflectance = 0
                obj.TextureID = ""
                if obj.Material == Enum.Material.Glass or obj.Material == Enum.Material.Neon
                or obj.Material == Enum.Material.ForceField or obj.Material == Enum.Material.Water then
                    obj.Material = Enum.Material.SmoothPlastic
                end
                pcall(function() sethidden(obj, "CollisionFidelity", 2) end)
                pcall(function() sethidden(obj, "FluidFidelity",     0) end)
            elseif obj:IsA("BasePart") and not obj:IsA("Terrain") then
                obj.CastShadow = false obj.Reflectance = 0
                if obj.Material == Enum.Material.Glass or obj.Material == Enum.Material.Neon
                or obj.Material == Enum.Material.ForceField or obj.Material == Enum.Material.Water then
                    obj.Material = Enum.Material.SmoothPlastic
                end
            elseif obj:IsA("Sound") and not obj:IsDescendantOf(LocalPlayer) then
                obj.RollOffMaxDistance = 30 obj.RollOffMinDistance = 5
                obj.EmitterSize = 5 obj.Volume = math.min(obj.Volume, 0.3)
            elseif obj:IsA("SoundEffect") then
                obj.Enabled = false
            end
        end)
    end
end

