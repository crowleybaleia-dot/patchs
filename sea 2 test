local function SafeLanding(wpPos, afterLand)
    local root = GetRoot()
    local c    = GetChar()
    if not root or not c then return end
    local ray = workspace:Raycast(
        Vector3.new(wpPos.X, TrackSettings.TravelHeight, wpPos.Z),
        Vector3.new(0, -TrackSettings.TravelHeight - 500, 0),
        rayParams
    )
    local groundY = ray and ray.Position.Y or wpPos.Y
    local safePos = CFrame.new(wpPos.X, groundY + TrackSettings.FloatHeight, wpPos.Z)
    root.Anchored = true
    root.AssemblyLinearVelocity  = Vector3.zero
    root.AssemblyAngularVelocity = Vector3.zero
    StopFloat()
    PurgePhysics()
    task.wait(0.1)
    c:PivotTo(safePos)
    DashBypass()
    task.wait(0.1)
    root.Anchored = false
    local hum = c:FindFirstChildOfClass("Humanoid")
    if hum then hum:ChangeState(Enum.HumanoidStateType.Freefall) end
    task.wait(0.4)
    if afterLand then afterLand() end
end

