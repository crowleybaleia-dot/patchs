local function ReturnToFarm()
    currentWaypointIndex  = 3
    waypointsDone         = false
    isLanding             = false
    isGroundMode          = not FARM_WAYPOINT.fly
    TrackSettings.Enabled = true
    RifleSettings.Enabled = true
    RifleSettings.ShowESP = true
    StartNoclip()
    StartFloat()
    if trackConn then trackConn:Disconnect() trackConn = nil end
    trackConn = RunService.Heartbeat:Connect(function()
        if not TrackSettings.Enabled then return end
        local root = GetRoot()
        if not root then return end
        local now = tick()
        if now - lastStam > TrackSettings.StamInterval then lastStam = now DashBypass() end
        local wp        = FARM_WAYPOINT
        local myPos     = root.Position
        local horizDist = Vector3.new(myPos.X - wp.pos.X, 0, myPos.Z - wp.pos.Z).Magnitude
        if horizDist <= TrackSettings.ArrivalDist then
            root.AssemblyLinearVelocity = Vector3.zero
            if trackConn then trackConn:Disconnect() trackConn = nil end
            waypointsDone = true TrackSettings.Enabled = false StopFloat()
            return
        end
        local dir   = Vector3.new(wp.pos.X - myPos.X, 0, wp.pos.Z - myPos.Z).Unit
        local diffY = wp.pos.Y - myPos.Y
        root.AssemblyLinearVelocity = Vector3.new(
            dir.X * TrackSettings.GroundSpeed,
            math.clamp(diffY * 10, -30, 30),
            dir.Z * TrackSettings.GroundSpeed
        )
    end)
end

local GoToNPC

local function WatchQuestComplete()
    if progressConn then progressConn:Disconnect() progressConn = nil end
    local ok, Progress = pcall(function()
        return LocalPlayer.PlayerGui
            :FindFirstChild("Quest"):FindFirstChild("Main")
            :FindFirstChild("Info"):FindFirstChild("Top")
            :FindFirstChild("Progress")
    end)
    if not ok or not Progress then
        task.wait(2)
        if questEnabled then WatchQuestComplete() end
        return
    end
    progressConn = Progress:GetPropertyChangedSignal("Text"):Connect(function()
        local current = tonumber(Progress.Text:match("^(%d+)")) or 0
        local total   = tonumber(Progress.Text:match("/ (%d+)")) or 0
        if current == 0 and total > 0 and not questDone and not questRunning and questEnabled then
            questDone = true
            if progressConn then progressConn:Disconnect() progressConn = nil end
            task.spawn(function()
                task.wait(0.3)
                questDone = false
                if questEnabled then GoToNPC() end
            end)
        end
    end)
end

local function TakeQuest()
    pcall(function() QuestRemote:InvokeServer({"npcChat", true}) end)
    task.wait(0.5)
    pcall(function() QuestRemote:InvokeServer({"takequest", QuestSettings.QuestName}) end)
    task.wait(0.5)
    questRunning = false
