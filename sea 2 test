local function SlidsSafeLanding(wpPos, afterLand)
    local root = SlidsGetRoot()
    local c    = LocalPlayer.Character
    if not root or not c then return end
    local ray = workspace:Raycast(
        Vector3.new(wpPos.X, SlidsSettings.TravelHeight, wpPos.Z),
        Vector3.new(0, -SlidsSettings.TravelHeight - 500, 0),
        slidsRayParams
    )
    local groundY = ray and ray.Position.Y or wpPos.Y
    local safePos = CFrame.new(wpPos.X, groundY + SlidsSettings.FloatHeight, wpPos.Z)
    root.Anchored = true
    root.AssemblyLinearVelocity  = Vector3.zero
    root.AssemblyAngularVelocity = Vector3.zero
    SlidsStopFloat()
    task.wait(0.1)
    c:PivotTo(safePos)
    SlidsDashBypass()
    task.wait(0.1)
    root.Anchored = false
    local hum = SlidsGetHum()
    if hum then hum:ChangeState(Enum.HumanoidStateType.Freefall) end
    task.wait(0.4)
    if afterLand then afterLand() end
end
local function SlidsStartTrack()
    if slidsTrackConn then slidsTrackConn:Disconnect() end
    slidsTrackConn = RunService.Heartbeat:Connect(function()
        if not SlidsSettings.Enabled then return end
        if slidsIsLanding then return end
        local root = SlidsGetRoot()
        if not root then return end
        local now = tick()
        if now - slidsLastStam > SlidsSettings.StamInterval then
            slidsLastStam = now
            SlidsDashBypass()
        end
        if slidsWaypointsDone or not slidsCurrentDestination then
            root.AssemblyLinearVelocity = Vector3.zero
            return
        end
        local dest      = slidsCurrentDestination
        local myPos     = root.Position
        local horizDist = Vector3.new(myPos.X - dest.X, 0, myPos.Z - dest.Z).Magnitude
        if horizDist <= SlidsSettings.ArrivalDist then
            root.AssemblyLinearVelocity = Vector3.zero
            SlidsStopTrack()
            slidsIsLanding = true
            task.spawn(function()
                SlidsSafeLanding(dest, function()
                    slidsIsLanding     = false
                    slidsWaypointsDone = true
                    SlidsFullCleanup()
                    pcall(function()
                        BarbiUI:Notify({ Title="🏃 Island Travel", Message="Chegou em: " .. (slidsCurrentDestinationName or "?"), Type="success", Duration=4 })
                    end)
                end)
            end)
            return
        end
        local dir = Vector3.new(dest.X - myPos.X, 0, dest.Z - myPos.Z).Unit
        root.AssemblyLinearVelocity = Vector3.new(
            dir.X * SlidsSettings.FlySpeed,
            root.AssemblyLinearVelocity.Y,
            dir.Z * SlidsSettings.FlySpeed
        )
    end)
end
