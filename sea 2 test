local function ESPRemove(island)
    local e = espMap[island]
    if e then
        if e.billboard and e.billboard.Parent then e.billboard:Destroy() end
        if e.anchor    and e.anchor.Parent    then e.anchor:Destroy()    end
    end
    espMap[island] = nil
end
local function ESPRemoveAll() for island in pairs(espMap) do ESPRemove(island) end end
local function ESPUpdate()
    local root = ESPGetRoot()
    if not root then return end
    local seen = {}
    for _, island in ipairs(IslandsFolder:GetChildren()) do
        seen[island] = true
        if espMap[island] and not espMap[island].part.Parent then ESPRemove(island) end
        if not espMap[island] then
            local part, needsAnchor = ESPFindPart(island)
            if needsAnchor or not part then
                local anchor = ESPCreateAnchor(island)
                ESPCreate(island, anchor) espMap[island].anchor = anchor
            else ESPCreate(island, part) end
        end
        local e = espMap[island]
        if not e then continue end
        local dist = (root.Position - e.part.Position).Magnitude
        local w, h, ts = ESPGetSizeStep(dist)
        e.billboard.Size = UDim2.new(0,w,0,h)
        e.nameLabel.TextSize = ts e.distLabel.TextSize = 9
        e.distLabel.Text = ESPFormatDist(dist)
    end
    for island in pairs(espMap) do if not seen[island] then ESPRemove(island) end end
end
local function ESPStart()
    if espHeartbeat then return end
    espHeartbeat = RunService.Heartbeat:Connect(function() pcall(ESPUpdate) end)
end
local function ESPStop()
    if espHeartbeat then espHeartbeat:Disconnect() espHeartbeat = nil end
    ESPRemoveAll()
end

