-- Speed Hack
RunService.Heartbeat:Connect(function()
    if not QOLSettings.SpeedEnabled then return end
    local char = LocalPlayer.Character
    if not char then return end
    local hum  = char:FindFirstChildOfClass("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    if not hum or not root then return end
    local dir = hum.MoveDirection
    if dir.Magnitude > 0 then
        local vel = root.AssemblyLinearVelocity
        local newV = dir * (hum.WalkSpeed + QOLSettings.SpeedBoost)
        root.AssemblyLinearVelocity = Vector3.new(newV.X, vel.Y, newV.Z)
    end
end)

-- Infinite Jump
local function QOL_EnableInfJump()
    if _infJumpConn then _infJumpConn:Disconnect() end
    getgenv()._LastJump = 0
    _infJumpConn = UserInputService.JumpRequest:Connect(function()
        if not QOLSettings.InfiniteJump then return end
        if tick() - getgenv()._LastJump < 0.1 then return end
        getgenv()._LastJump = tick()
        local char = LocalPlayer.Character
        local hum  = char and char:FindFirstChildOfClass("Humanoid")
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if not hum or not root then return end
        if hum.JumpPower == 0 then
            root.CFrame = root.CFrame + Vector3.new(0, 7, 0)
            root.Velocity = Vector3.zero
        else
            root.AssemblyLinearVelocity = Vector3.new(
                root.AssemblyLinearVelocity.X, 50, root.AssemblyLinearVelocity.Z
            )
        end
    end)
end
QOL_EnableInfJump()

