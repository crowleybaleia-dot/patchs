local function ESPCreateAnchor(island)
    local pos = Vector3.new(0,0,0)
    local ok, cf = pcall(function() return island:GetBoundingBox() end)
    if ok and cf then pos = cf.Position end
    local a = Instance.new("Part")
    a.Name = "IslandESP_Anchor" a.Size = Vector3.new(1,1,1) a.Position = pos
    a.Anchored = true a.CanCollide = false a.Transparency = 1 a.CastShadow = false
    a.Parent = island
