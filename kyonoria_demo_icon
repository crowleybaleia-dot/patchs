-- ================================================
--   ABA 1 - AIMBOT
-- ================================================

local TabAim   = Window:AddTab('Aimbot',      'rbxassetid://SEU_ICON_AIMBOT')
local GrpEsq   = TabAim:AddLeftGroupbox('Configurações', 'rbxassetid://7733960981', Color3.new(1, 1, 1))
local GrpDir   = TabAim:AddRightGroupbox('Opções', 'rbxassetid://7733715400', Color3.new(1, 1, 1))

-- Toggle simples
GrpEsq:AddToggle('AimEnabled', {
    Text     = 'Ativar Aimbot',
    Default  = false,
    Tooltip  = 'Liga/desliga o aimbot',
    Callback = function(v)
        print('[Aimbot] Ativo:', v)
    end,
})

-- Toggle + KeyPicker (Toggle: aperta ativa, aperta dnv desativa)
GrpEsq:AddToggle('AimKey_Toggle', {
    Text     = 'Aim Key',
    Default  = false,
    Callback = function(v)
        print('[Aim Key] Estado:', v)
    end,
}):AddKeyPicker('AimKey', {
    Default         = 'C',
    Text            = 'Aim',
    Mode            = 'Toggle',
    SyncToggleState = true,
    Callback = function(active)
        print('[Aim Key] Ativo:', active)
    end,
})

-- Slider FOV
GrpEsq:AddSlider('AimFov', {
    Text     = 'FOV',
    Min      = 1,
    Max      = 360,
    Default  = 90,
    Suffix   = '°',
    Rounding = 0,
    Callback = function(v)
        print('[FOV]', v)
    end,
})

-- Slider Smooth
GrpEsq:AddSlider('AimSmooth', {
    Text     = 'Smooth',
    Min      = 1,
    Max      = 20,
    Default  = 5,
    Rounding = 1,
    Callback = function(v)
        print('[Smooth]', v)
    end,
})

-- Dropdown hitpart
GrpDir:AddDropdown('Hitpart', {
    Text     = 'Hitpart',
    Values   = { 'Head', 'Neck', 'UpperTorso', 'HumanoidRootPart' },
    Default  = 'Head',
    Callback = function(v)
        print('[Hitpart]', v)
    end,
})

-- Dropdown player alvo
GrpDir:AddDropdown('PlayerAlvo', {
    Text        = 'Player Alvo',
    Values      = {},
    SpecialType = 'Player',
    Callback    = function(v)
        print('[Alvo]', v)
    end,
})

GrpDir:AddDivider()

-- Botão simples
GrpDir:AddButton({
    Text = 'Testar Aimbot',
    Func = function()
        Library:Notify('Aimbot testado!', 3)
        print('[Btn] Testado!')
    end,
    DoubleClick = false,
    Tooltip     = 'Clique para testar',
})

-- Botão duplo clique
GrpDir:AddButton({
    Text        = 'Reset (duplo clique)',
    Func        = function()
        Options.AimFov:SetValue(90)
        Options.AimSmooth:SetValue(5)
        Library:Notify('Resetado!', 2)
    end,
    DoubleClick = true,
    Tooltip     = 'Clique duas vezes para resetar',
})

