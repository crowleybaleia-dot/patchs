-- ================================================
--   JANELA
-- ================================================

local Window = Library:CreateWindow({
    Title        = 'Demo Completa',
    Center       = true,
    AutoShow     = true,
    MenuFadeTime = 0.2,
    TabPadding   = 8,
    Size         = UDim2.fromOffset(550, 600),
