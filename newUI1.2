--[[
    BarbiUI — Linoria Style
    • Toggles quadrados (checkbox)
    • Keybind pequeno e compacto
    • Tabs flat sem arredondamento
    • Zero BorderRadius exceto onde necessário
--]]

local Players          = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local TweenService     = game:GetService("TweenService")
local CoreGui          = game:GetService("CoreGui")
local HttpService      = game:GetService("HttpService")

local LocalPlayer = Players.LocalPlayer
local Mouse = LocalPlayer:GetMouse()

local _wf = rawget(_G,"writefile")  or function() end
local _rf  = rawget(_G,"readfile")   or function() return "{}" end
local _lf  = rawget(_G,"listfiles")  or function() return {} end
local _mf  = rawget(_G,"makefolder") or function() end
local _df  = rawget(_G,"delfile")    or function() end
local _if  = rawget(_G,"isfolder")   or function() return false end

-- ── Theme (Linoria-like) ───────────────────────────────────────────────────
local T = {
    Bg          = Color3.fromRGB(15,  15,  20 ),
    Bg2         = Color3.fromRGB(22,  22,  30 ),
    Bg3         = Color3.fromRGB(30,  30,  40 ),
    Border      = Color3.fromRGB(50,  50,  65 ),
    Border2     = Color3.fromRGB(70,  70,  90 ),
    Purple      = Color3.fromRGB(110, 80,  220),
    PurpleLight = Color3.fromRGB(150, 120, 255),
    PurpleDim   = Color3.fromRGB(60,  40,  120),
    Cyan        = Color3.fromRGB(0,   210, 200),
    White       = Color3.fromRGB(220, 220, 230),
    Gray        = Color3.fromRGB(140, 140, 160),
    DarkGray    = Color3.fromRGB(80,  80,  100),
    Success     = Color3.fromRGB(50,  200, 140),
    Warning     = Color3.fromRGB(240, 180, 40 ),
    Error       = Color3.fromRGB(230, 90,  90 ),
    Font        = Enum.Font.Code,
    FontBold    = Enum.Font.GothamBold,
}

-- ── Helpers ────────────────────────────────────────────────────────────────
local U = {}

function U.New(cls, props)
    local ok, obj = pcall(Instance.new, cls)
    if not ok then return nil end
    pcall(function()
        if obj:IsA("GuiObject") then
            obj.BorderSizePixel = 0
        end
    end)
    for k, v in pairs(props or {}) do
        if k ~= "Parent" then pcall(function() obj[k] = v end) end
    end
    if props and props.Parent then pcall(function() obj.Parent = props.Parent end) end
    return obj
end

function U.Tw(obj, props, t, sty, dir)
    if not obj or not obj.Parent then return end
    pcall(function()
        TweenService:Create(
            obj,
            TweenInfo.new(t or 0.15, sty or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out),
            props
        ):Play()
    end)
end

-- UDim helpers — NO corner by default
function U.Pad(p, t, r, b, l)
    return U.New("UIPadding", {
        PaddingTop    = UDim.new(0, t or 4),
        PaddingRight  = UDim.new(0, r or 4),
        PaddingBottom = UDim.new(0, b or 4),
        PaddingLeft   = UDim.new(0, l or 4),
        Parent = p
    })
end

function U.List(p, dir, pad)
    return U.New("UIListLayout", {
        FillDirection      = dir or Enum.FillDirection.Vertical,
        SortOrder          = Enum.SortOrder.LayoutOrder,
        Padding            = UDim.new(0, pad or 0),
        HorizontalAlignment= Enum.HorizontalAlignment.Left,
        VerticalAlignment  = Enum.VerticalAlignment.Top,
        Parent = p
    })
end

function U.Stroke(p, col, th)
    return U.New("UIStroke", {Color=col, Thickness=th or 1, Parent=p})
end

function U.Time()
    local ok, t = pcall(os.time)
    if not ok then return "00:00:00" end
    local ok2, s = pcall(os.date, "%H:%M:%S", t)
    return ok2 and s or "00:00:00"
end

-- ── Config ─────────────────────────────────────────────────────────────────
local Cfg = {_data={}}
function Cfg:Reg(k,o) self._data[k]=o end
function Cfg:Save(name)
    if not name or name=="" then return false end
    local t={}
    for k,o in pairs(self._data) do pcall(function() t[k]=o:Get() end) end
    return pcall(function()
        if not _if("BarbiUI") then _mf("BarbiUI") end
        _wf("BarbiUI/"..name..".json", HttpService:JSONEncode(t))
    end)
end
function Cfg:Load(name)
    if not name or name=="" then return false end
    return pcall(function()
        local t=HttpService:JSONDecode(_rf("BarbiUI/"..name..".json"))
        for k,v in pairs(t) do if self._data[k] then self._data[k]:Set(v,false) end end
    end)
end
function Cfg:List()
    local r={}
    pcall(function()
        if not _if("BarbiUI") then _mf("BarbiUI") return end
        for _,f in ipairs(_lf("BarbiUI")) do
            local n=f:match("([^/\\]+)%.json$") if n then table.insert(r,n) end
        end
    end)
    return r
end

-- ── Notifs ─────────────────────────────────────────────────────────────────
local Notifs={sg=nil,holder=nil,n=0}
function Notifs:Init()
    if self.sg and self.sg.Parent then return end
    self.sg=U.New("ScreenGui",{Name="BUI_Notif",ResetOnSpawn=false,ZIndexBehavior=Enum.ZIndexBehavior.Global,IgnoreGuiInset=true,Parent=CoreGui})
    self.holder=U.New("Frame",{BackgroundTransparency=1,Size=UDim2.new(0,240,1,0),Position=UDim2.new(1,-248,0,0),Parent=self.sg})
    U.New("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,VerticalAlignment=Enum.VerticalAlignment.Bottom,HorizontalAlignment=Enum.HorizontalAlignment.Right,Padding=UDim.new(0,3),Parent=self.holder})
    U.Pad(self.holder,0,0,10,0)
end
function Notifs:Send(cfg)
    self:Init()
    cfg=cfg or {}
    local cols={info=T.Purple,success=T.Success,warning=T.Warning,error=T.Error}
    local col=cols[cfg.Type or "info"] or T.Purple
    self.n=self.n+1
    local f=U.New("Frame",{BackgroundColor3=T.Bg2,Size=UDim2.new(1,0,0,28),LayoutOrder=self.n,ClipsDescendants=true,Parent=self.holder})
    U.Stroke(f,T.Border)
    -- colored left bar
    U.New("Frame",{BackgroundColor3=col,Size=UDim2.new(0,2,1,0),Parent=f})
    local inner=U.New("Frame",{BackgroundTransparency=1,Position=UDim2.new(0,8,0,0),Size=UDim2.new(1,-8,1,0),Parent=f})
    U.New("TextLabel",{BackgroundTransparency=1,Size=UDim2.new(0,0,1,0),AutomaticSize=Enum.AutomaticSize.X,Text=(cfg.Title or ""),TextColor3=T.White,Font=T.FontBold,TextSize=9,TextXAlignment=Enum.TextXAlignment.Left,Parent=inner})
    U.New("TextLabel",{BackgroundTransparency=1,Position=UDim2.new(0,60,0,0),Size=UDim2.new(1,-60,1,0),Text=(cfg.Message or ""),TextColor3=T.Gray,Font=T.Font,TextSize=9,TextXAlignment=Enum.TextXAlignment.Left,Parent=inner})
    f.Position=UDim2.new(1,4,0,0)
    U.Tw(f,{Position=UDim2.new(0,0,0,0)},0.2)
    task.delay(cfg.Duration or 4,function()
        if not f or not f.Parent then return end
        U.Tw(f,{Position=UDim2.new(1,4,0,0)},0.15)
        task.delay(0.18,function() if f and f.Parent then f:Destroy() end end)
    end)
end

-- ══════════════════════════════════════════════════════════════════════════
--  BarbiUI
-- ══════════════════════════════════════════════════════════════════════════
local BarbiUI={}
BarbiUI.__index=BarbiUI
function BarbiUI:Notify(cfg) Notifs:Send(cfg) end

function BarbiUI:CreateWindow(cfg)
    cfg=cfg or {}
    local title  = cfg.Title  or "BarbiUI"
    local sub    = cfg.Sub    or ""
    local key    = cfg.Key    or Enum.KeyCode.RightShift
    local winW   = cfg.Width  or 550
    local winH   = cfg.Height or 480
    local TITLE_H= 22
    local TAB_H  = 24

    local sg=U.New("ScreenGui",{Name="BUI_"..title,ResetOnSpawn=false,ZIndexBehavior=Enum.ZIndexBehavior.Global,IgnoreGuiInset=true,Parent=CoreGui})
    local win=U.New("Frame",{BackgroundColor3=T.Bg,Size=UDim2.new(0,winW,0,0),Position=UDim2.new(0.5,-winW/2,0.5,-winH/2),ClipsDescendants=false,Parent=sg})
    U.Stroke(win,T.Border)

    local clip=U.New("Frame",{BackgroundTransparency=1,Size=UDim2.new(1,0,1,0),ClipsDescendants=true,Parent=win})
    U.New("Frame",{BackgroundColor3=T.Bg,Size=UDim2.new(1,0,1,0),Parent=clip})

    -- ── Titlebar ────────────────────────────────────────────────────────
    local tb=U.New("Frame",{BackgroundColor3=T.Bg2,Size=UDim2.new(1,0,0,TITLE_H),ZIndex=10,Parent=clip})
    U.New("Frame",{BackgroundColor3=T.Border,Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,1,-1),ZIndex=11,Parent=tb})

    local titleStr = title..(sub~="" and ("  |  "..sub) or "")
    U.New("TextLabel",{BackgroundTransparency=1,Position=UDim2.new(0,6,0,0),Size=UDim2.new(1,-80,1,0),Text=titleStr,TextColor3=T.White,Font=T.Font,TextSize=10,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=11,Parent=tb})

    local clk=U.New("TextLabel",{BackgroundTransparency=1,Position=UDim2.new(0.5,-25,0,0),Size=UDim2.new(0,50,1,0),Text=U.Time(),TextColor3=T.DarkGray,Font=T.Font,TextSize=8,ZIndex=11,Parent=tb})
    task.spawn(function() while clk and clk.Parent do clk.Text=U.Time() task.wait(1) end end)

    -- close / minimize (pequenos, no canto)
    local function CtrlBtn(sym, xOff, hcol, cb)
        local b=U.New("TextButton",{BackgroundColor3=T.Bg3,Position=UDim2.new(1,xOff,0.5,-6),Size=UDim2.new(0,12,0,12),Text=sym,TextColor3=T.Gray,Font=T.FontBold,TextSize=8,ZIndex=15,Parent=tb})
        U.Stroke(b,T.Border)
        b.MouseEnter:Connect(function() U.Tw(b,{BackgroundColor3=hcol,TextColor3=T.White},0.08) end)
        b.MouseLeave:Connect(function() U.Tw(b,{BackgroundColor3=T.Bg3,TextColor3=T.Gray},0.08) end)
        b.MouseButton1Click:Connect(cb)
    end
    CtrlBtn("×",-10, T.Error,   function() U.Tw(win,{Size=UDim2.new(0,winW,0,0)},0.15) task.wait(0.18) sg:Destroy() end)
    local minimized=false local savedH=winH
    CtrlBtn("−",-26, T.Warning, function()
        minimized=not minimized
        if minimized then
            savedH=win.Size.Y.Offset>(TITLE_H+TAB_H) and win.Size.Y.Offset or winH
            U.Tw(win,{Size=UDim2.new(0,winW,0,TITLE_H+TAB_H)},0.15)
        else
            U.Tw(win,{Size=UDim2.new(0,winW,0,savedH)},0.2)
        end
    end)

    -- drag
    local drag,dS,dP=false
    tb.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=true dS=i.Position dP=win.Position end end)
    UserInputService.InputChanged:Connect(function(i) if drag and i.UserInputType==Enum.UserInputType.MouseMovement then local d=i.Position-dS win.Position=UDim2.new(dP.X.Scale,dP.X.Offset+d.X,dP.Y.Scale,dP.Y.Offset+d.Y) end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end end)

    -- toggle visibility
    local vis=true local curKey=key
    UserInputService.InputBegan:Connect(function(i)
        if i.KeyCode~=curKey then return end
        vis=not vis
        if vis then win.Visible=true win.Size=UDim2.new(0,winW,0,TITLE_H) U.Tw(win,{Size=UDim2.new(0,winW,0,winH)},0.2)
        else U.Tw(win,{Size=UDim2.new(0,winW,0,TITLE_H)},0.15) task.wait(0.18) win.Visible=false end
    end)

    -- ── Tab bar ──────────────────────────────────────────────────────────
    -- Linoria style: tabs lado a lado, texto branco, underline no ativo
    local tabBar=U.New("Frame",{BackgroundColor3=T.Bg2,Size=UDim2.new(1,0,0,TAB_H),Position=UDim2.new(0,0,0,TITLE_H),ZIndex=9,Parent=clip})
    U.New("Frame",{BackgroundColor3=T.Border,Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,1,-1),ZIndex=10,Parent=tabBar})
    U.List(tabBar, Enum.FillDirection.Horizontal, 0)

    local contentY=TITLE_H+TAB_H
    local contentArea=U.New("Frame",{BackgroundTransparency=1,Position=UDim2.new(0,0,0,contentY),Size=UDim2.new(1,0,1,-contentY-18),ClipsDescendants=true,Parent=clip})

    -- status bar
    local stBar=U.New("Frame",{BackgroundColor3=T.Bg2,Size=UDim2.new(1,0,0,18),Position=UDim2.new(0,0,1,-18),ZIndex=9,Parent=clip})
    U.New("Frame",{BackgroundColor3=T.Border,Size=UDim2.new(1,0,0,1),Parent=stBar})
    U.New("TextLabel",{BackgroundTransparency=1,Position=UDim2.new(0,6,0,0),Size=UDim2.new(0.5,0,1,0),Text="injected  •  bypassed",TextColor3=T.DarkGray,Font=T.Font,TextSize=7,TextXAlignment=Enum.TextXAlignment.Left,Parent=stBar})
    U.New("TextLabel",{BackgroundTransparency=1,Position=UDim2.new(0.5,0,0,0),Size=UDim2.new(0.5,-4,1,0),Text="BarbiUI",TextColor3=T.DarkGray,Font=T.Font,TextSize=7,TextXAlignment=Enum.TextXAlignment.Right,Parent=stBar})

    -- Win object
    local Win={_tabs={},_active=nil,_ord=0}

    local function ActivateTab(data)
        for _,it in ipairs(Win._tabs) do
            it.page.Visible=false
            U.Tw(it.lbl,{TextColor3=T.Gray},0.1)
            if it.ul then it.ul.Visible=false end
        end
        data.page.Visible=true
        Win._active=data
        U.Tw(data.lbl,{TextColor3=T.White},0.1)
        if data.ul then data.ul.Visible=true end
    end

    local function MakeTabBtn(name, badge)
        Win._ord=Win._ord+1
        -- Container do botão
        local wrap=U.New("Frame",{BackgroundColor3=T.Bg2,Size=UDim2.new(0,0,1,0),AutomaticSize=Enum.AutomaticSize.X,LayoutOrder=Win._ord,Parent=tabBar})
        U.New("Frame",{BackgroundColor3=T.Border,Size=UDim2.new(0,1,1,0),Position=UDim2.new(1,-1,0,0),Parent=wrap}) -- separador direito

        local btn=U.New("TextButton",{BackgroundTransparency=1,Size=UDim2.new(1,0,1,0),Text="",ZIndex=3,Parent=wrap})
        U.Pad(wrap,0,12,0,12)

        local lbl=U.New("TextLabel",{BackgroundTransparency=1,Size=UDim2.new(0,0,1,-2),AutomaticSize=Enum.AutomaticSize.X,Text=name,TextColor3=T.Gray,Font=T.Font,TextSize=10,ZIndex=2,Parent=wrap})

        -- underline ativo (Linoria style)
        local ul=U.New("Frame",{BackgroundColor3=T.Purple,Size=UDim2.new(1,0,0,2),AnchorPoint=Vector2.new(0,1),Position=UDim2.new(0,0,1,0),Visible=false,ZIndex=4,Parent=wrap})

        if badge then
            local bf=U.New("Frame",{BackgroundColor3=T.PurpleDim,Position=UDim2.new(1,2,0.5,-7),Size=UDim2.new(0,12,0,10),ZIndex=5,Parent=wrap})
            U.New("TextLabel",{BackgroundTransparency=1,Size=UDim2.new(1,0,1,0),Text=tostring(badge),TextColor3=T.PurpleLight,Font=T.FontBold,TextSize=7,ZIndex=6,Parent=bf})
        end

        btn.MouseEnter:Connect(function()
            if Win._active and Win._active.btn~=btn then U.Tw(lbl,{TextColor3=T.White},0.08) end
        end)
        btn.MouseLeave:Connect(function()
            if Win._active and Win._active.btn~=btn then U.Tw(lbl,{TextColor3=T.Gray},0.08) end
        end)
        return btn, lbl, ul
    end

    local function MakePage()
        local page=U.New("ScrollingFrame",{BackgroundTransparency=1,Size=UDim2.new(1,0,1,0),ScrollBarThickness=2,ScrollBarImageColor3=T.Purple,CanvasSize=UDim2.new(0,0,0,0),AutomaticCanvasSize=Enum.AutomaticSize.Y,Visible=false,Parent=contentArea})
        U.Pad(page,4,4,4,4) U.List(page,nil,0)
        return page
    end

    local function MakeGrid(page)
        local grid=U.New("Frame",{BackgroundTransparency=1,Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,LayoutOrder=0,Parent=page})
        local L=U.New("Frame",{BackgroundTransparency=1,Position=UDim2.new(0,0,0,0),Size=UDim2.new(0.5,-1,0,0),AutomaticSize=Enum.AutomaticSize.Y,Parent=grid})
        U.List(L,nil,3)
        local R=U.New("Frame",{BackgroundTransparency=1,Position=UDim2.new(0.5,1,0,0),Size=UDim2.new(0.5,-1,0,0),AutomaticSize=Enum.AutomaticSize.Y,Parent=grid})
        U.List(R,nil,3)
        return L,R
    end

    -- Card: sem arredondamento, como Linoria
    local function MakeCard(parent, lo)
        local card=U.New("Frame",{BackgroundColor3=T.Bg2,Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,LayoutOrder=lo or 1,Parent=parent})
        U.Stroke(card,T.Border)
        U.List(card,nil,0)
        return card
    end

    -- Header do card: linha colorida à esquerda + texto, como Linoria
    local function CardHeader(card, left, right)
        local hdr=U.New("Frame",{BackgroundColor3=T.Bg3,Size=UDim2.new(1,0,0,20),LayoutOrder=0,Parent=card})
        U.New("Frame",{BackgroundColor3=T.Border,Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,1,-1),Parent=hdr})
        if right then
            -- dois títulos (como "Local" / "Enemy" ou "Render" / "World")
            U.New("Frame",{BackgroundColor3=T.Border,Size=UDim2.new(0,1,0.7,0),AnchorPoint=Vector2.new(0,0.5),Position=UDim2.new(0.5,0,0.5,0),Parent=hdr})
            U.New("TextLabel",{BackgroundTransparency=1,Position=UDim2.new(0,0,0,0),Size=UDim2.new(0.5,0,1,0),Text=left,TextColor3=T.Gray,Font=T.Font,TextSize=9,TextXAlignment=Enum.TextXAlignment.Center,Parent=hdr})
            U.New("TextLabel",{BackgroundTransparency=1,Position=UDim2.new(0.5,0,0,0),Size=UDim2.new(0.5,0,1,0),Text=right,TextColor3=T.Gray,Font=T.Font,TextSize=9,TextXAlignment=Enum.TextXAlignment.Center,Parent=hdr})
        else
            U.New("TextLabel",{BackgroundTransparency=1,Position=UDim2.new(0,8,0,0),Size=UDim2.new(1,-8,1,0),Text=left,TextColor3=T.Gray,Font=T.Font,TextSize=9,TextXAlignment=Enum.TextXAlignment.Left,Parent=hdr})
        end
    end

    -- ── Config tab ───────────────────────────────────────────────────────
    do
        local btn,lbl,ul=MakeTabBtn("Config","cfg")
        local page=MakePage()
        local L,R=MakeGrid(page)
        local c1=MakeCard(L,1) CardHeader(c1,"Config")

        local iWrap=U.New("Frame",{BackgroundTransparency=1,Size=UDim2.new(1,0,0,26),LayoutOrder=1,Parent=c1})
        U.Pad(iWrap,3,4,2,4)
        local box=U.New("TextBox",{BackgroundColor3=T.Bg3,Size=UDim2.new(1,0,1,0),Text="",PlaceholderText="config name...",TextColor3=T.White,PlaceholderColor3=T.DarkGray,Font=T.Font,TextSize=9,ClearTextOnFocus=false,Parent=iWrap})
        U.Stroke(box,T.Border2)
        box.Focused:Connect(function() U.Tw(box,{BackgroundColor3=T.Bg},0.1) end)
        box.FocusLost:Connect(function() U.Tw(box,{BackgroundColor3=T.Bg3},0.1) end)

        local bRow=U.New("Frame",{BackgroundTransparency=1,Size=UDim2.new(1,0,0,26),LayoutOrder=2,Parent=c1})
        U.Pad(bRow,3,4,3,4)
        local bS=U.New("TextButton",{BackgroundColor3=T.PurpleDim,Size=UDim2.new(0.5,-2,1,0),Text="Save",TextColor3=T.White,Font=T.Font,TextSize=9,ClipsDescendants=true,Parent=bRow})
        U.Stroke(bS,T.Purple)
        bS.MouseEnter:Connect(function() U.Tw(bS,{BackgroundColor3=T.Purple},0.08) end)
        bS.MouseLeave:Connect(function() U.Tw(bS,{BackgroundColor3=T.PurpleDim},0.08) end)
        local bR=U.New("TextButton",{BackgroundColor3=T.Bg3,Position=UDim2.new(0.5,2,0,0),Size=UDim2.new(0.5,-2,1,0),Text="Reset",TextColor3=T.Gray,Font=T.Font,TextSize=9,ClipsDescendants=true,Parent=bRow})
        U.Stroke(bR,T.Border)
        bR.MouseEnter:Connect(function() U.Tw(bR,{BackgroundColor3=T.Bg},0.08) end)
        bR.MouseLeave:Connect(function() U.Tw(bR,{BackgroundColor3=T.Bg3},0.08) end)

        local chips=U.New("Frame",{BackgroundTransparency=1,Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,LayoutOrder=3,Parent=c1})
        U.Pad(chips,2,4,4,4)
        U.New("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,Wraps=true,Padding=UDim.new(0,3),Parent=chips})

        local function RefChips()
            for _,c in ipairs(chips:GetChildren()) do if not c:IsA("UIListLayout") and not c:IsA("UIPadding") then c:Destroy() end end
            local list=Cfg:List()
            if #list==0 then U.New("TextLabel",{BackgroundTransparency=1,Size=UDim2.new(1,0,0,14),Text="no configs",TextColor3=T.DarkGray,Font=T.Font,TextSize=8,Parent=chips}) return end
            for _,n in ipairs(list) do
                local ch=U.New("TextButton",{BackgroundColor3=T.Bg3,Size=UDim2.new(0,0,0,16),AutomaticSize=Enum.AutomaticSize.X,Text=n.." ×",TextColor3=T.PurpleLight,Font=T.Font,TextSize=8,ClipsDescendants=true,Parent=chips})
                U.Pad(ch,0,5,0,5) U.Stroke(ch,T.Border)
                ch.MouseButton1Click:Connect(function()
                    local mp=UserInputService:GetMouseLocation()
                    if mp.X>ch.AbsolutePosition.X+ch.AbsoluteSize.X-14 then
                        pcall(function() _df("BarbiUI/"..n..".json") end)
                        Notifs:Send({Title="Config",Message='Deleted "'..n..'"',Type="warning",Duration=2}) RefChips()
                    else
                        local ok=Cfg:Load(n)
                        Notifs:Send({Title="Config",Message=ok and 'Loaded "'..n..'"' or "Error",Type=ok and "success" or "error",Duration=3})
                    end
                end)
            end
        end

        bS.MouseButton1Click:Connect(function() local ok=Cfg:Save(box.Text) Notifs:Send({Title="Config",Message=ok and 'Saved "'..box.Text..'"' or "Error",Type=ok and "success" or "error",Duration=3}) RefChips() end)
        bR.MouseButton1Click:Connect(function()
            if box.Text=="" then Notifs:Send({Title="Config",Message="Type a name first.",Type="warning",Duration=2}) return end
            pcall(function() _df("BarbiUI/"..box.Text..".json") end)
            local ok=Cfg:Save(box.Text) Notifs:Send({Title="Config",Message=ok and 'Reset "'..box.Text..'"' or "Error",Type=ok and "success" or "error",Duration=3}) RefChips()
        end)

        -- UI Key
        local c2=MakeCard(L,2) CardHeader(c2,"UI Key")
        local kr=U.New("Frame",{BackgroundTransparency=1,Size=UDim2.new(1,0,0,26),LayoutOrder=1,Parent=c2})
        U.Pad(kr,3,4,3,4)
        U.New("TextLabel",{BackgroundTransparency=1,Size=UDim2.new(0.55,0,1,0),Text="Open / Close",TextColor3=T.White,Font=T.Font,TextSize=9,TextXAlignment=Enum.TextXAlignment.Left,Parent=kr})
        local listening=false
        local kchip=U.New("TextButton",{BackgroundColor3=T.Bg3,Position=UDim2.new(0.55,0,0.5,-9),Size=UDim2.new(0.45,0,0,18),Text=key.Name,TextColor3=T.PurpleLight,Font=T.Font,TextSize=9,Parent=kr})
        U.Stroke(kchip,T.Border)
        kchip.MouseButton1Click:Connect(function()
            if listening then return end listening=true kchip.Text="..." kchip.TextColor3=T.Warning
            local con; con=UserInputService.InputBegan:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.Keyboard then
                    if i.KeyCode~=Enum.KeyCode.Escape then curKey=i.KeyCode kchip.Text=i.KeyCode.Name else kchip.Text=curKey.Name end
                    kchip.TextColor3=T.PurpleLight listening=false con:Disconnect()
                end
            end)
        end)

        local td={btn=btn,lbl=lbl,ul=ul,page=page}
        table.insert(Win._tabs,td)
        btn.MouseButton1Click:Connect(function() ActivateTab(td) RefChips() end)
    end

    -- ── AddTab ────────────────────────────────────────────────────────────
    function Win:AddTab(tc)
        tc=tc or {}
        local name=tc.Name or ("Tab "..#Win._tabs+1)
        local btn,lbl,ul=MakeTabBtn(name,tc.Badge)
        local page=MakePage()
        local L,R=MakeGrid(page)
        local colIdx=0
        local td={btn=btn,lbl=lbl,ul=ul,page=page}
        table.insert(Win._tabs,td)
        btn.MouseButton1Click:Connect(function() ActivateTab(td) end)
        if #Win._tabs==2 then ActivateTab(td) end

        local Tab={}

        function Tab:AddSection(sc)
            sc=sc or {}
            colIdx=colIdx+1
            local col=(colIdx%2==1) and L or R
            local card=MakeCard(col,colIdx)
            CardHeader(card, sc.Name or "Section", sc.Name2)
            local Sec={} local iOrd=0

            -- linha simples
            local function Row(h)
                iOrd=iOrd+1
                local r=U.New("Frame",{BackgroundTransparency=1,Size=UDim2.new(1,0,0,h or 22),LayoutOrder=iOrd,Parent=card})
                U.Pad(r,2,6,2,6)
                return r
            end

            -- ── Toggle: QUADRADO, tipo Linoria ──────────────────────────
            function Sec:AddToggle(c)
                c=c or {}
                local tName=c.Name or "Toggle"
                local state=c.Default or false
                local cb=c.Callback or function() end
                local row=Row(20)

                -- Checkbox quadrado 10×10
                local box=U.New("Frame",{
                    BackgroundColor3=state and T.Cyan or T.Bg,
                    Position=UDim2.new(0,0,0.5,-5),
                    Size=UDim2.new(0,10,0,10),
                    Parent=row
                })
                U.Stroke(box, state and T.Cyan or T.Border2)

                -- Check mark (pequeno traço branco quando ativo)
                local chk=U.New("TextLabel",{
                    BackgroundTransparency=1,
                    Size=UDim2.new(1,0,1,0),
                    Text=state and "✓" or "",
                    TextColor3=T.Bg,
                    Font=T.FontBold,
                    TextSize=7,
                    Parent=box
                })

                -- Nome
                U.New("TextLabel",{
                    BackgroundTransparency=1,
                    Position=UDim2.new(0,16,0,0),
                    Size=UDim2.new(1,-52,1,0),
                    Text=tName,
                    TextColor3=T.White,
                    Font=T.Font,
                    TextSize=10,
                    TextXAlignment=Enum.TextXAlignment.Left,
                    Parent=row
                })

                -- Color slot (quadrado roxo pequeno no canto, como Linoria)
                local cslot=U.New("Frame",{
                    BackgroundColor3=T.Purple,
                    Position=UDim2.new(1,-14,0.5,-7),
                    Size=UDim2.new(0,14,0,14),
                    Parent=row
                })
                U.Stroke(cslot,T.Border)

                local o={}
                local function Upd(s,ani)
                    if ani then
                        U.Tw(box,{BackgroundColor3=s and T.Cyan or T.Bg},0.1)
                    else
                        box.BackgroundColor3=s and T.Cyan or T.Bg
                    end
                    pcall(function() box:FindFirstChildOfClass("UIStroke"):Destroy() end)
                    U.Stroke(box, s and T.Cyan or T.Border2)
                    chk.Text=s and "✓" or ""
                    ActivePanel_Set(tName,s)
                end

                function o:Set(v,silent) state=v Upd(v,true) if not silent then cb(v) end end
                function o:Get() return state end
                Upd(state,false)
                Cfg:Reg(tName,o)

                local hit=U.New("TextButton",{BackgroundTransparency=1,Size=UDim2.new(1,-20,1,0),Text="",ZIndex=5,Parent=row})
                hit.MouseButton1Click:Connect(function() state=not state Upd(state,true) cb(state) end)
                return o
            end

            -- ── Slider ──────────────────────────────────────────────────
            function Sec:AddSlider(c)
                c=c or {}
                local mn=c.Min or 0 local mx=c.Max or 100 local def=c.Default or mn
                local cb=c.Callback or function() end local sfx=c.Suffix or "" local isInt=c.Integer or false
                iOrd=iOrd+1
                local wrap=U.New("Frame",{BackgroundTransparency=1,Size=UDim2.new(1,0,0,32),LayoutOrder=iOrd,Parent=card})
                U.Pad(wrap,2,6,2,6)

                -- top row: name + value
                local top=U.New("Frame",{BackgroundTransparency=1,Size=UDim2.new(1,0,0,13),Parent=wrap})
                U.New("TextLabel",{BackgroundTransparency=1,Size=UDim2.new(0.6,0,1,0),Text=c.Name or "Slider",TextColor3=T.White,Font=T.Font,TextSize=9,TextXAlignment=Enum.TextXAlignment.Left,Parent=top})
                local vLbl=U.New("TextLabel",{BackgroundTransparency=1,Position=UDim2.new(0.6,0,0,0),Size=UDim2.new(0.4,0,1,0),TextColor3=T.Cyan,Font=T.Font,TextSize=8,TextXAlignment=Enum.TextXAlignment.Right,Parent=top})

                -- track
                local track=U.New("TextButton",{BackgroundColor3=T.Bg3,Position=UDim2.new(0,0,0,16),Size=UDim2.new(1,0,0,6),Text="",Parent=wrap})
                U.Stroke(track,T.Border)
                local fill=U.New("Frame",{BackgroundColor3=T.Cyan,Size=UDim2.new((mx~=mn and (def-mn)/(mx-mn) or 0),0,1,0),Parent=track})

                local val=def
                local function Fmt(v) return tostring(isInt and v or math.round(v*10)/10) end
                vLbl.Text=Fmt(def).."/"..tostring(mx)..sfx

                local function Upd(v)
                    v=math.clamp(v,mn,mx) if isInt then v=math.round(v) end val=v
                    local p=(mx~=mn) and (v-mn)/(mx-mn) or 0
                    fill.Size=UDim2.new(p,0,1,0)
                    vLbl.Text=Fmt(v).."/"..tostring(mx)..sfx cb(v)
                end

                local drag2=false
                track.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drag2=true Upd(mn+(mx-mn)*math.clamp((i.Position.X-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)) end end)
                local mc=UserInputService.InputChanged:Connect(function(i) if drag2 and i.UserInputType==Enum.UserInputType.MouseMovement then Upd(mn+(mx-mn)*math.clamp((i.Position.X-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)) end end)
                local ec=UserInputService.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drag2=false end end)
                card.AncestryChanged:Connect(function() if not card.Parent then if mc then mc:Disconnect() end if ec then ec:Disconnect() end end end)

                local o={} function o:Set(v) Upd(v) end function o:Get() return val end
                if c.Name then Cfg:Reg(c.Name,o) end
                return o
            end

            -- ── Keybind: PEQUENO e compacto ─────────────────────────────
            function Sec:AddBind(c)
                c=c or {}
                local bkey=c.Default local lst=false
                local cb=c.Callback or function() end
                local toggle=c.Toggle
                local row=Row(20)

                U.New("TextLabel",{
                    BackgroundTransparency=1,
                    Size=UDim2.new(0.6,0,1,0),
                    Text=c.Name or "Keybind",
                    TextColor3=T.White,
                    Font=T.Font,
                    TextSize=10,
                    TextXAlignment=Enum.TextXAlignment.Left,
                    Parent=row
                })

                -- chip pequeno (só o nome da tecla, estilo Linoria)
                local chip=U.New("TextButton",{
                    BackgroundColor3=T.Bg3,
                    Position=UDim2.new(0.6,0,0.5,-8),
                    Size=UDim2.new(0.4,0,0,16),
                    Text=bkey and "["..bkey.Name.."]" or "[None]",
                    TextColor3=T.PurpleLight,
                    Font=T.Font,
                    TextSize=8,
                    Parent=row
                })
                U.Stroke(chip,T.Border)

                -- listener de ação (sem filtro gp)
                UserInputService.InputBegan:Connect(function(i)
                    if lst then return end
                    if bkey and i.KeyCode==bkey then
                        cb()
                        if toggle then toggle:Set(not toggle:Get(),false) end
                    end
                end)

                chip.MouseButton1Click:Connect(function()
                    if lst then return end lst=true chip.Text="[  ...  ]" chip.TextColor3=T.Warning
                    local con; con=UserInputService.InputBegan:Connect(function(i)
                        if i.UserInputType==Enum.UserInputType.Keyboard then
                            if i.KeyCode==Enum.KeyCode.Escape then
                                chip.Text=bkey and "["..bkey.Name.."]" or "[None]"
                            else
                                bkey=i.KeyCode chip.Text="["..i.KeyCode.Name.."]"
                            end
                            chip.TextColor3=T.PurpleLight lst=false con:Disconnect()
                        end
                    end)
                end)

                local o={}
                function o:Set(v) bkey=v chip.Text=v and "["..v.Name.."]" or "[None]" chip.TextColor3=v and T.PurpleLight or T.DarkGray end
                function o:Get() return bkey end
                if c.Name then Cfg:Reg(c.Name,{Get=function() return bkey and bkey.Name or "None" end,Set=function(_,v) local kc=v~="None" and Enum.KeyCode[v] or nil o:Set(kc) end}) end
                return o
            end

            -- ── Dropdown ─────────────────────────────────────────────────
            function Sec:AddDropdown(c)
                c=c or {} local opts=c.Options or {} local sel=c.Default or opts[1] local cb=c.Callback or function() end local open=false
                iOrd=iOrd+1
                local wrap=U.New("Frame",{BackgroundTransparency=1,Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,LayoutOrder=iOrd,Parent=card})
                U.Pad(wrap,2,6,2,6)
                U.New("TextLabel",{BackgroundTransparency=1,Size=UDim2.new(1,0,0,13),Text=c.Name or "Dropdown",TextColor3=T.Gray,Font=T.Font,TextSize=9,TextXAlignment=Enum.TextXAlignment.Left,Parent=wrap})
                local db=U.New("TextButton",{BackgroundColor3=T.Bg3,Position=UDim2.new(0,0,0,15),Size=UDim2.new(1,0,0,20),Text="",ClipsDescendants=false,Parent=wrap})
                U.Stroke(db,T.Border)
                local selLbl=U.New("TextLabel",{BackgroundTransparency=1,Position=UDim2.new(0,6,0,0),Size=UDim2.new(1,-20,1,0),Text=tostring(sel or ""),TextColor3=T.White,Font=T.Font,TextSize=9,TextXAlignment=Enum.TextXAlignment.Left,Parent=db})
                local chev=U.New("TextLabel",{BackgroundTransparency=1,Position=UDim2.new(1,-16,0,0),Size=UDim2.new(0,14,1,0),Text="▾",TextColor3=T.PurpleLight,Font=T.Font,TextSize=10,Parent=db})
                local dl=U.New("Frame",{BackgroundColor3=T.Bg2,Position=UDim2.new(0,0,1,1),Size=UDim2.new(1,0,0,0),ZIndex=100,ClipsDescendants=true,Visible=false,Parent=db})
                U.Stroke(dl,T.Border) U.List(dl)
                for i,opt in ipairs(opts) do
                    local ob=U.New("TextButton",{BackgroundColor3=T.Bg3,BackgroundTransparency=opt==sel and 0 or 1,Size=UDim2.new(1,0,0,20),Text="",LayoutOrder=i,ZIndex=101,Parent=dl})
                    U.New("TextLabel",{BackgroundTransparency=1,Position=UDim2.new(0,6,0,0),Size=UDim2.new(1,-6,1,0),Text=tostring(opt),TextColor3=opt==sel and T.PurpleLight or T.White,Font=T.Font,TextSize=9,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=102,Parent=ob})
                    ob.MouseEnter:Connect(function() U.Tw(ob,{BackgroundTransparency=0,BackgroundColor3=T.Bg3},0.06) end)
                    ob.MouseLeave:Connect(function() U.Tw(ob,{BackgroundTransparency=opt==sel and 0 or 1},0.06) end)
                    ob.MouseButton1Click:Connect(function()
                        sel=opt selLbl.Text=tostring(opt) open=false
                        U.Tw(chev,{Rotation=0},0.1) U.Tw(dl,{Size=UDim2.new(1,0,0,0)},0.12)
                        task.wait(0.14) if dl and dl.Parent then dl.Visible=false end cb(sel)
                    end)
                end
                local th=#opts*20
                local function OpenDD() open=true dl.Visible=true dl.Size=UDim2.new(1,0,0,0) U.Tw(dl,{Size=UDim2.new(1,0,0,th)},0.18) U.Tw(chev,{Rotation=180},0.1) end
                local function CloseDD() open=false U.Tw(chev,{Rotation=0},0.1) U.Tw(dl,{Size=UDim2.new(1,0,0,0)},0.12) task.wait(0.14) if dl and dl.Parent then dl.Visible=false end end
                db.MouseButton1Click:Connect(function() if open then task.spawn(CloseDD) else OpenDD() end end)
                UserInputService.InputBegan:Connect(function(i)
                    if not open or i.UserInputType~=Enum.UserInputType.MouseButton1 then return end
                    local mp=i.Position local function inB(obj) if not obj or not obj.Parent then return false end local p,s=obj.AbsolutePosition,obj.AbsoluteSize return mp.X>=p.X and mp.X<=p.X+s.X and mp.Y>=p.Y and mp.Y<=p.Y+s.Y end
                    if not inB(db) and not inB(dl) then task.defer(CloseDD) end
                end)
                local o={} function o:Set(v) sel=v selLbl.Text=tostring(v) end function o:Get() return sel end
                if c.Name then Cfg:Reg(c.Name,o) end
                return o
            end

            -- ── TextBox ──────────────────────────────────────────────────
            function Sec:AddTextBox(c)
                c=c or {} local cb=c.Callback or function() end local numOnly=c.NumberOnly or false
                iOrd=iOrd+1
                local wrap=U.New("Frame",{BackgroundTransparency=1,Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,LayoutOrder=iOrd,Parent=card})
                U.Pad(wrap,2,6,2,6)
                U.New("TextLabel",{BackgroundTransparency=1,Size=UDim2.new(1,0,0,13),Text=c.Name or "Input",TextColor3=T.Gray,Font=T.Font,TextSize=9,TextXAlignment=Enum.TextXAlignment.Left,Parent=wrap})
                local b=U.New("TextBox",{BackgroundColor3=T.Bg3,Position=UDim2.new(0,0,0,15),Size=UDim2.new(1,0,0,20),Text=c.Default or "",PlaceholderText=c.Placeholder or "...",TextColor3=T.White,PlaceholderColor3=T.DarkGray,Font=T.Font,TextSize=9,ClearTextOnFocus=false,Parent=wrap})
                U.Stroke(b,T.Border)
                b.Focused:Connect(function() U.Tw(b,{BackgroundColor3=T.Bg},0.1) end)
                b.FocusLost:Connect(function(enter) U.Tw(b,{BackgroundColor3=T.Bg3},0.1) if numOnly and not tonumber(b.Text) then b.Text="" end if enter then cb(b.Text) end end)
                b:GetPropertyChangedSignal("Text"):Connect(function() if numOnly then b.Text=b.Text:gsub("[^%d%.%-]","") end end)
                local o={} function o:Set(v) b.Text=tostring(v) end function o:Get() return b.Text end
                return o
            end

            -- ── Button ───────────────────────────────────────────────────
            function Sec:AddButton(c)
                c=c or {} iOrd=iOrd+1
                local wrap=U.New("Frame",{BackgroundTransparency=1,Size=UDim2.new(1,0,0,26),LayoutOrder=iOrd,Parent=card})
                U.Pad(wrap,3,6,3,6)
                local b=U.New("TextButton",{BackgroundColor3=T.Bg3,Size=UDim2.new(1,0,1,0),Text=c.Name or "Button",TextColor3=T.White,Font=T.Font,TextSize=9,ClipsDescendants=true,Parent=wrap})
                U.Stroke(b,T.Border)
                b.MouseEnter:Connect(function() U.Tw(b,{BackgroundColor3=T.Bg,TextColor3=T.PurpleLight},0.08) end)
                b.MouseLeave:Connect(function() U.Tw(b,{BackgroundColor3=T.Bg3,TextColor3=T.White},0.08) end)
                b.MouseButton1Click:Connect(function() ;(c.Callback or function()end)() end)
                if c.Description then
                    iOrd=iOrd+1
                    U.New("TextLabel",{BackgroundTransparency=1,Size=UDim2.new(1,0,0,13),LayoutOrder=iOrd,Text=c.Description,TextColor3=T.DarkGray,Font=T.Font,TextSize=8,TextXAlignment=Enum.TextXAlignment.Center,Parent=card})
                end
            end

            -- ── Label ────────────────────────────────────────────────────
            function Sec:AddLabel(text)
                iOrd=iOrd+1
                local r=U.New("Frame",{BackgroundTransparency=1,Size=UDim2.new(1,0,0,18),LayoutOrder=iOrd,Parent=card})
                U.Pad(r,0,6,0,6)
                U.New("TextLabel",{BackgroundTransparency=1,Size=UDim2.new(1,0,1,0),Text=text,TextColor3=T.Gray,Font=T.Font,TextSize=9,TextXAlignment=Enum.TextXAlignment.Left,TextWrapped=true,Parent=r})
            end

            -- ── Separator ────────────────────────────────────────────────
            function Sec:AddSeparator(lbl)
                iOrd=iOrd+1
                local r=U.New("Frame",{BackgroundTransparency=1,Size=UDim2.new(1,0,0,13),LayoutOrder=iOrd,Parent=card})
                U.Pad(r,0,6,0,6)
                U.New("Frame",{BackgroundColor3=T.Border,AnchorPoint=Vector2.new(0,0.5),Position=UDim2.new(0,0,0.5,0),Size=UDim2.new(1,0,0,1),Parent=r})
                if lbl then
                    local lb=U.New("Frame",{BackgroundColor3=T.Bg2,AnchorPoint=Vector2.new(0,0.5),Position=UDim2.new(0,6,0.5,0),Size=UDim2.new(0,0,0,10),AutomaticSize=Enum.AutomaticSize.X,Parent=r})
                    U.Pad(lb,0,4,0,4)
                    U.New("TextLabel",{BackgroundTransparency=1,Size=UDim2.new(0,0,1,0),AutomaticSize=Enum.AutomaticSize.X,Text=lbl,TextColor3=T.DarkGray,Font=T.Font,TextSize=7,Parent=lb})
                end
            end

            return Sec
        end

        return Tab
    end

    -- stub pra não quebrar quando AddToggle chama ActivePanel_Set
    -- (o painel lateral está omitido nessa versão clean)
    ActivePanel_Set = function() end

    win.Size=UDim2.new(0,winW,0,0)
    task.wait(0.04)
    U.Tw(win,{Size=UDim2.new(0,winW,0,winH)},0.25)
    return Win
end

