-- ══════════════════════════════════════════════════════
--   Demo — Linoria UI Library
-- ══════════════════════════════════════════════════════

local Library = loadstring(game:HttpGet(
    "https://raw.githubusercontent.com/crowleybaleia-dot/patchs/refs/heads/main/newUI1.3"
))()

local Toggles = getgenv().Toggles
local Options  = getgenv().Options

-- ── Janela ─────────────────────────────────────────────
local Window = Library:CreateWindow({
    Title    = "BarbiUI | Phantom Forces",
    AutoShow = true,
    Size     = UDim2.fromOffset(560, 520),
})

-- ══════════════════════════════════════════════════════
--   ABA 1 — Legit
-- ══════════════════════════════════════════════════════
local TabLegit = Window:AddTab("Legit")

-- ── Aimbot (esquerda) ──────────────────────────────────
local GbAim = TabLegit:AddLeftGroupbox("Aimbot")

GbAim:AddToggle("Aimbot", {
    Text     = "Aimbot",
    Default  = false,
    Callback = function(v) print("[Aimbot]", v) end,
})

GbAim:AddToggle("SilentAim", {
    Text     = "Silent Aim",
    Default  = false,
    Callback = function(v) print("[Silent Aim]", v) end,
})

GbAim:AddToggle("Prediction", {
    Text     = "Prediction",
    Default  = true,
    Callback = function(v) print("[Prediction]", v) end,
})

GbAim:AddSlider("FOV", {
    Text     = "FOV",
    Default  = 90,
    Min      = 1,
    Max      = 360,
    Rounding = 0,
    Callback = function(v) print("[FOV]", v) end,
})

GbAim:AddSlider("Smooth", {
    Text     = "Smooth",
    Default  = 50,
    Min      = 1,
    Max      = 100,
    Rounding = 0,
    Callback = function(v) print("[Smooth]", v) end,
})

GbAim:AddDropdown("TargetPart", {
    Text    = "Target Part",
    Values  = { "Head", "Torso", "Nearest" },
    Default = "Head",
    Callback = function(v) print("[Target Part]", v) end,
})

Toggles["Aimbot"]:AddKeyPicker("AimbotKey", {
    Default  = "MB2",
    Text     = "Aimbot key",
    Mode     = "Hold",
    Callback = function(v) print("[Aimbot key]", v) end,
})

-- ── Triggerbot (direita) ───────────────────────────────
local GbTrig = TabLegit:AddRightGroupbox("Triggerbot")

GbTrig:AddToggle("Triggerbot", {
    Text     = "Triggerbot",
    Default  = false,
    Callback = function(v) print("[Triggerbot]", v) end,
})

GbTrig:AddSlider("TriggerDelay", {
    Text     = "Delay (ms)",
    Default  = 80,
    Min      = 0,
    Max      = 500,
    Rounding = 0,
    Callback = function(v) print("[Delay]", v) end,
})

Toggles["Triggerbot"]:AddKeyPicker("TriggerKey", {
    Default  = "C",
    Text     = "Trigger key",
    Mode     = "Hold",
    Callback = function(v) print("[Trigger key]", v) end,
})

GbTrig:AddDivider()

GbTrig:AddButton({
    Text = "Reset Triggerbot",
    Func = function()
        Options["TriggerDelay"]:SetValue(80)
        Toggles["Triggerbot"]:SetValue(false)
        Library:Notify("Triggerbot resetado.", 3)
    end,
})

