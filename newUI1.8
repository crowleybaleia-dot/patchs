-- ══════════════════════════════════════════════════════
--   ABA 4 — Miscellaneous
-- ══════════════════════════════════════════════════════
local TabMisc = Window:AddTab("Miscellaneous")

local GbMove = TabMisc:AddLeftGroupbox("Movement")

GbMove:AddToggle("Bhop", {
    Text     = "Bunny Hop",
    Default  = false,
    Callback = function(v) print("[Bhop]", v) end,
})

GbMove:AddToggle("AutoSprint", {
    Text     = "Auto Sprint",
    Default  = false,
    Callback = function(v) print("[Auto Sprint]", v) end,
})

GbMove:AddSlider("Walkspeed", {
    Text     = "Walkspeed",
    Default  = 16,
    Min      = 16,
    Max      = 300,
    Rounding = 0,
    Callback = function(v)
        local lp = game:GetService("Players").LocalPlayer
        if lp and lp.Character and lp.Character:FindFirstChild("Humanoid") then
            lp.Character.Humanoid.WalkSpeed = v
        end
    end,
})

GbMove:AddSlider("JumpPower", {
    Text     = "Jump Power",
    Default  = 50,
    Min      = 50,
    Max      = 300,
    Rounding = 0,
    Callback = function(v)
        local lp = game:GetService("Players").LocalPlayer
        if lp and lp.Character and lp.Character:FindFirstChild("Humanoid") then
            lp.Character.Humanoid.JumpPower = v
        end
    end,
})

GbMove:AddButton({
    Text = "Reset Movement",
    Func = function()
        Options["Walkspeed"]:SetValue(16)
        Options["JumpPower"]:SetValue(50)
        Library:Notify("Movement resetado.", 2)
    end,
})

local GbUtil = TabMisc:AddRightGroupbox("Utility")

GbUtil:AddToggle("Fullbright", {
    Text     = "Fullbright",
    Default  = false,
    Callback = function(v)
        local L = game:GetService("Lighting")
        L.Brightness = v and 10 or 1
        if v then L.ClockTime = 14 end
    end,
})

GbUtil:AddToggle("NoFog", {
    Text     = "No Fog",
    Default  = false,
    Callback = function(v)
        game:GetService("Lighting").FogEnd = v and 999999 or 1000
    end,
})

GbUtil:AddDivider()

GbUtil:AddInput("SpectatePlayer", {
    Text        = "Spectate Player",
    Placeholder = "Nome do jogador...",
    Finished    = true,
    Callback    = function(v)
        if v ~= "" then Library:Notify("Spectate: " .. v, 3) end
    end,
})

GbUtil:AddButton({
    Text = "Notif de Teste",
    Func = function()
        Library:Notify("Notificação funcionando!", 4)
    end,
})

-- ══════════════════════════════════════════════════════
--   ABA 5 — Settings
-- ══════════════════════════════════════════════════════
local TabSettings = Window:AddTab("Settings")

local GbUI = TabSettings:AddLeftGroupbox("Interface")

GbUI:AddLabel("Tecla padrão: RightShift / RightControl")

GbUI:AddToggle("ShowWatermark", {
    Text     = "Mostrar Watermark",
    Default  = true,
    Callback = function(v) Library:SetWatermarkVisibility(v) end,
})

GbUI:AddDivider()

GbUI:AddButton({
    Text = "Reset Geral",
    Func = function()
        Toggles["Aimbot"]:SetValue(false)
        Toggles["SilentAim"]:SetValue(false)
        Toggles["Nametags"]:SetValue(true)
        Toggles["Boxes"]:SetValue(true)
        Toggles["Healthbars"]:SetValue(true)
        Options["FOV"]:SetValue(90)
        Options["Smooth"]:SetValue(50)
        Options["Walkspeed"]:SetValue(16)
        Options["JumpPower"]:SetValue(50)
        Library:Notify("Tudo resetado!", 3)
    end,
})

GbUI:AddButton({
    Text = "Destruir UI",
    Func = function()
        Library:Notify("Até mais!", 2)
        task.wait(2)
        Library:Unload()
    end,
})

local GbCfg = TabSettings:AddRightGroupbox("Info")
GbCfg:AddLabel("BarbiUI Demo v1.0")
GbCfg:AddLabel("Tecla: RightShift abre/fecha a UI.")
GbCfg:AddLabel("MB2 segura para Aimbot.")
GbCfg:AddLabel("C segura para Triggerbot.")
GbCfg:AddLabel("X toggle para Rage Aimbot.")

-- ══════════════════════════════════════════════════════
